---
interface Props {
  en: string;
  ja?: string;
  note?: string;
  id?: string;
  align?: "left" | "center";
  size?: "md" | "lg";
}

const { en, ja, note, id, align = "left", size = "md" } = Astro.props;
---

<header class={`c-section-heading c-section-heading--${align} c-section-heading--${size}`} id={id}>
  {ja && <p class="c-section-heading__ja" data-inview style="--inview-i: 0">
    <span class="c-section-heading__icon" aria-hidden="true"></span>
    {ja}
  </p>}
  <h2 class="c-section-heading__en" data-inview style="--inview-i: 1">{en}</h2>
  {note && <p class="c-section-heading__note" data-inview style="--inview-i: 2">{note}</p>}
</header>
