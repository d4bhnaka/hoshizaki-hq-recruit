---
interface Props {
  basePath?: string;
}

const { basePath = "./" } = Astro.props;

type FooterItem = { href: string; label: string; external?: boolean };
type FooterColumn = {
  heading: string | { href: string; label: string } | null;
  href?: string;
  items: FooterItem[];
};

const columns: FooterColumn[] = [
  {
    heading: "採用TOP",
    href: basePath,
    items: [],
  },
  {
    heading: null,
    items: [
      { href: `${basePath}message/`, label: "採用メッセージ" },
      { href: `${basePath}fact/`, label: "What's HOSHIZAKI" },
      { href: `${basePath}strategy/`, label: "Beyond HOSHIZAKI" },
      { href: `${basePath}job/`, label: "Team HOSHIZAKI" },
      { href: `${basePath}person/`, label: "先輩たちの「ここに決めた」" },
    ],
  },
  {
    heading: { href: `${basePath}special/`, label: "SPECIAL CONTENTS" },
    items: [
      {
        href: `${basePath}special/crosstalk/`,
        label: "クロストーク - 若手が語るはたらく環境",
      },
      { href: `${basePath}special/project/`, label: "プロジェクトストーリー" },
      {
        href: `${basePath}special/special-talk/`,
        label: "スペシャルトーク - ホシザキの技術と未来",
      },
    ],
  },
  {
    heading: null,
    items: [
      { href: `${basePath}environment/`, label: "はたらく環境を知る" },
      { href: `${basePath}requirement/`, label: "募集要項" },
      { href: `${basePath}internship/`, label: "インターンシップ情報" },
      {
        href: "https://www.hoshizaki.co.jp/",
        label: "ホシザキ企業サイト",
        external: true,
      },
    ],
  },
];
---

<footer class="l-footer">
  <div class="l-footer__inner">
    <nav class="l-footer__nav" aria-label="フッターナビゲーション">
      {
        columns.map((column) => (
          <div class="l-footer__col">
            {column.heading && typeof column.heading === "string" && (
              <p class="l-footer__heading">
                <a class="l-footer__heading-link" href={column.href}>
                  {column.heading}
                </a>
              </p>
            )}
            {column.heading && typeof column.heading === "object" && (
              <p class="l-footer__heading">
                <a class="l-footer__heading-link" href={column.heading.href}>
                  {column.heading.label}
                </a>
              </p>
            )}
            {column.items.length > 0 && (
              <ul class="l-footer__list">
                {column.items.map((item) => (
                  <li>
                    <a
                      class:list={[
                        "l-footer__link",
                        { "l-footer__link--external": item.external },
                      ]}
                      href={item.href}
                      {...(item.external
                        ? { target: "_blank", rel: "noopener" }
                        : {})}
                    >
                      {item.label}
                      {item.external && (
                        <img
                          class="l-footer__external-icon"
                          src={`${basePath}images/common/external-link.svg`}
                          alt="（外部サイト）"
                          width="12"
                          height="12"
                        />
                      )}
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </div>
        ))
      }
    </nav>
  </div>
  <p class="l-footer__wordmark" aria-hidden="true">
    <img src={`${basePath}images/common/hoshizaki.svg`} alt="" />
  </p>
</footer>
