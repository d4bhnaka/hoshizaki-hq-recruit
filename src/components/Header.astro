---
interface Props {
  basePath?: string;
  variant?: "light" | "solid";
  logoSrc?: string;
}

const {
  basePath = "./",
  variant = "light",
  logoSrc = `${Astro.props.basePath ?? "./"}images/common/hoshizaki-logo-mark-header.png`,
} = Astro.props;

// 現在表示中のページを判定する。URL の先頭セグメントをキーにする。
//   "/" → ""（トップ） / "/message/" → "message" / "/person/01/" → "person"
// person 詳細などの下層ページも先頭セグメントで親メニュー項目に一致させる。
const currentKey = Astro.url.pathname.split("/").filter(Boolean)[0] ?? "";

// Figma 518:1195 (Navigation) をベースに、スペシャルコンテンツを加えた 9 項目。
// アイスキューブアイコンは「現在表示中のページ」の項目先頭に表示し、現在地を示す。
const drawerLinks = [
  { href: `${basePath}`, label: "トップページ", key: "" },
  { href: `${basePath}message/`, label: "採用メッセージ", key: "message" },
  { href: `${basePath}fact/`, label: "数字で見るホシザキ", key: "fact" },
  { href: `${basePath}strategy/`, label: "ホシザキの事業戦略", key: "strategy" },
  { href: `${basePath}job/`, label: "ホシザキの職種紹介", key: "job" },
  { href: `${basePath}person/`, label: "はたらく人を知る", key: "person" },
  { href: `${basePath}environment/`, label: "はたらく環境を知る", key: "environment" },
  {
    href: `${basePath}special/`,
    label: "スペシャルコンテンツ",
    key: "special",
    children: [
      { href: `${basePath}special/crosstalk/`, label: "クロストーク" },
      { href: `${basePath}special/project/`, label: "プロジェクトストーリー" },
      { href: `${basePath}special/special-talk/`, label: "スペシャルトーク" },
    ],
  },
  { href: `${basePath}requirement/`, label: "募集要項", key: "requirement" },
  { href: `${basePath}internship/`, label: "インターンシップ", key: "internship" },
];

// ヘッダー右上の CTA ボタン。ラベルはホバー時に一文字ずつめくれる
// ロールオーバー演出をするため、レンダリング側で 1 文字ずつ span に分割する。
const headerCtas = [
  { href: `${basePath}internship/`, label: "インターンシップ", external: false },
  {
    href: "https://hoshizaki-corporation-hr.snar.jp/index.aspx",
    label: "応募はこちら",
    external: true,
  },
];
---

<header class={`l-header l-header--${variant}`} data-variant={variant}>
  <div class="l-header__inner">
    <a
      class={`l-header__logo${currentKey === "internship" ? " l-header__logo--wide" : ""}`}
      href={basePath}
      aria-label="ホシザキ採用サイト トップ"
    >
      <img
        src={logoSrc}
        alt="HOSHIZAKI"
        onerror="this.style.display='none';this.nextElementSibling.style.display='inline';"
      />
      <span class="l-header__logo-fallback" style="display:none;">HOSHIZAKI</span>
    </a>
    <div class="l-header__actions">
      {
        headerCtas.map((cta) => (
          <a
            class="l-header__cta"
            href={cta.href}
            aria-label={cta.label}
            {...(cta.external
              ? { target: "_blank", rel: "noopener noreferrer" }
              : {})}
          >
            <span class="l-header__cta-icon" aria-hidden="true" />
            {/* ラベルは aria-hidden（読み上げは a の aria-label）。
                各文字は同じ文字を 2 枚重ね、ホバーで上にめくって入れ替える。
                --i は左からの添字で、ロールのディレイをずらし「一文字ずつ」見せる。 */}
            <span class="l-header__cta-label" aria-hidden="true">
              {Array.from(cta.label).map((ch, i) => (
                <span class="l-header__cta-char" style={`--i:${i}`}>
                  <span class="l-header__cta-char-text">{ch}</span>
                  <span class="l-header__cta-char-text">{ch}</span>
                </span>
              ))}
            </span>
          </a>
        ))
      }
      <button
        class="l-header__menu"
        type="button"
        aria-label="メニューを開く"
        aria-expanded="false"
        aria-controls="l-drawer"
        data-drawer-toggle
      >
        <span aria-hidden="true"></span>
        <span aria-hidden="true"></span>
        <span aria-hidden="true"></span>
      </button>
    </div>
  </div>

  <div class="l-drawer" id="l-drawer" hidden>
    <button
      class="l-drawer__backdrop"
      type="button"
      aria-label="メニューを閉じる"
      data-drawer-close
      tabindex="-1"></button>
    <aside class="l-drawer__panel" aria-label="メインナビゲーション">
      <button
        class="l-drawer__close"
        type="button"
        aria-label="メニューを閉じる"
        data-drawer-close>
        <span class="l-drawer__close-x" aria-hidden="true"></span>
      </button>
      <nav class="l-drawer__nav">
        <ul class="l-drawer__list">
          {
            drawerLinks.map((item, i) => {
              const isCurrent = item.key === currentKey;
              return (
                // --i: 開扉時のスタッガー（順次フェードイン）の遅延に使う添字
                <li class="l-drawer__item" style={`--i:${i}`}>
                  <a
                    class="l-drawer__link"
                    href={item.href}
                    aria-current={isCurrent ? "page" : undefined}
                  >
                    {/* アイコン用ガターは全項目で確保し、ラベル列を揃える。
                        画像は現在ページの項目だけに表示する。 */}
                    <span class="l-drawer__link-icon" aria-hidden="true">
                      {isCurrent && (
                        <img
                          src={`${basePath}images/common/ice-01.png`}
                          alt=""
                          onerror="this.style.display='none'"
                        />
                      )}
                    </span>
                    <span class="l-drawer__link-label">{item.label}</span>
                  </a>
                  {item.children && (
                    // スペシャルコンテンツ配下の個別ページへの子リンク。
                    <ul class="l-drawer__sublist">
                      {item.children.map((child) => (
                        <li class="l-drawer__subitem">
                          <a class="l-drawer__sublink" href={child.href}>
                            {child.label}
                          </a>
                        </li>
                      ))}
                    </ul>
                  )}
                </li>
              );
            })
          }
        </ul>
      </nav>
      <img
        class="l-drawer__bg"
        src={`${basePath}images/common/nav_bg.png`}
        alt=""
        aria-hidden="true"
      />
    </aside>
  </div>
</header>
