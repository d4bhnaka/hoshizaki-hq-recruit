---
interface Props {
  image: string;
  /** 職種（メタ行・左）。例「生産管理」 */
  jobType: string;
  /** 入社年バッジ（メタ行・右）。例「2024年 新卒入社」 */
  entry: string;
  body: string;
  /** カード左下のカテゴリタグ。例「技術系」 */
  category: string;
  /** When omitted, the card renders as a non-interactive <article>
   *  (個別詳細ページが未確定のため一覧ページではリンクなし). */
  href?: string;
}

const { image, jobType, entry, body, category, href } = Astro.props;

const bodyLines = body.split("／");
const Tag = href ? "a" : "article";
---

<Tag class="c-person-card" {...href ? { href } : {}}>
  <figure class="c-person-card__photo">
    <img
      class="c-person-card__photo-img"
      src={image}
      alt=""
      loading="lazy"
    />
  </figure>
  <div class="c-person-card__body">
    <div class="c-person-card__meta">
      <span class="c-person-card__job">{jobType}</span>
      <span class="c-person-card__badge">{entry}</span>
    </div>
    <p class="c-person-card__text">
      {
        bodyLines.map((line, i) => (
          <>
            {line}
            {i < bodyLines.length - 1 && <br />}
          </>
        ))
      }
    </p>
    <div class="c-person-card__footer">
      <span class="c-person-card__tag">{category}</span>
      <svg
        class="c-person-card__chevron"
        viewBox="0 0 320 512"
        aria-hidden="true"
        focusable="false"
      >
        <path
          fill="currentColor"
          d="M310.6 233.4c12.5 12.5 12.5 32.8 0 45.3l-192 192c-12.5 12.5-32.8 12.5-45.3 0s-12.5-32.8 0-45.3L242.7 256 73.4 86.6c-12.5-12.5-12.5-32.8 0-45.3s32.8-12.5 45.3 0l192 192z"
        ></path>
      </svg>
    </div>
  </div>
</Tag>
