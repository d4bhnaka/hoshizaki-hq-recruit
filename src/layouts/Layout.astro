---
interface Props {
  basePath?: string;
  title?: string;
  description?: string;
}

const {
  basePath = "./",
  title = "ホシザキ本社採用サイト",
  description = "ホシザキ株式会社 本社採用情報。新卒採用・インターンシップ情報を掲載しています。",
} = Astro.props;

// 本番ビルド以外（staging / dev）はクローラーをブロック
const isProduction = process.env.BUILD_ENV === "production";
const siteUrl = process.env.SITE_URL ?? "";

// 本番のみ canonical / og:url を絶対URLで出力
// site が `https://www.hoshizaki.co.jp/saiyou/` のようにサブパスを含むため、
// new URL(relativePath, siteUrl) で正しく結合する
const canonicalUrl =
  isProduction && siteUrl
    ? new URL(Astro.url.pathname.replace(/^\//, ""), siteUrl).toString()
    : null;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {!isProduction && <meta name="robots" content="noindex,nofollow" />}
    <meta name="description" content={description} />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="ホシザキ本社採用サイト" />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${basePath}favicon.svg`} />
    <link rel="icon" href={`${basePath}favicon.ico`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;500;600;700;800;900&family=Noto+Sans+JP:wght@400;500;700;900&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href={`${basePath}css/style.css`} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <script src={`${basePath}js/main.js`} defer is:inline></script>
  </body>
</html>
