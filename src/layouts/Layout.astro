---
interface Props {
  basePath?: string;
  title?: string;
  description?: string;
}

const {
  basePath = "./",
  title = "ホシザキ本社採用サイト",
  description = "ホシザキ株式会社 本社採用情報。新卒採用・インターンシップ情報を掲載しています。",
} = Astro.props;

// 本番ビルド以外（staging / dev）はクローラーをブロック
const isProduction = process.env.BUILD_ENV === "production";
const siteUrl = process.env.SITE_URL ?? "";

// 本番のみ canonical / og:url を絶対URLで出力
// site が `https://www.hoshizaki.co.jp/saiyou/` のようにサブパスを含むため、
// new URL(relativePath, siteUrl) で正しく結合する
const canonicalUrl =
  isProduction && siteUrl
    ? new URL(Astro.url.pathname.replace(/^\//, ""), siteUrl).toString()
    : null;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {
      /* ページ遷移アニメ（進入ガード）: 直前ページが離脱時に立てた
        sessionStorage フラグを *描画前に* 読み、進入アニメ .pt-enter を
        付与する。フラッシュ防止のため必ず head 内・同期実行で行う
        （deferred な main.js では遅すぎる）。スタイルは
        scss/object/component/_c-page-transition.scss、離脱側は js/main.js。 */
    }
    <script is:inline>
      (function () {
        try {
          if (
            window.matchMedia &&
            window.matchMedia("(prefers-reduced-motion: reduce)").matches
          )
            return;
          if (sessionStorage.getItem("pt:enter") === "1") {
            sessionStorage.removeItem("pt:enter");
            document.documentElement.classList.add("pt-enter");
          }
        } catch (e) {}
      })();
    </script>
    {/* Inview リビール（出現前の非表示ガード）: prefers-reduced-motion 非該当かつ
        IntersectionObserver 対応時のみ <html>.inview-ready を *描画前に* 付与する。
        この class が付いている時だけ [data-inview] を初期非表示にするため、
        JS 無効・低モーション環境ではコンテンツが消えず即表示される。
        実体の監視は js/main.js の initInview、スタイルは
        scss/object/utility/_u-inview.scss。 */}
    <script is:inline>
      (function () {
        try {
          if (
            window.matchMedia &&
            window.matchMedia("(prefers-reduced-motion: reduce)").matches
          )
            return;
          if (!("IntersectionObserver" in window)) return;
          document.documentElement.classList.add("inview-ready");
        } catch (e) {}
      })();
    </script>
    {!isProduction && <meta name="robots" content="noindex,nofollow" />}
    <meta name="description" content={description} />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="ホシザキ本社採用サイト" />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="icon" href={`${basePath}favicon.ico`} sizes="any" />
    <link
      rel="icon"
      type="image/png"
      sizes="192x192"
      href={`${basePath}icon-192.png`}
    />
    <link
      rel="icon"
      type="image/png"
      sizes="512x512"
      href={`${basePath}icon-512.png`}
    />
    <link rel="apple-touch-icon" href={`${basePath}apple-touch-icon.png`} />
    <!-- セルフホスト Web フォント（Barlow Condensed / Noto Sans JP）。public/css/fonts.css は webfont-selfhost スキルで自動生成 -->
    <link rel="stylesheet" href={`${basePath}css/fonts.css`} />
    <slot name="head" />
    <link rel="stylesheet" href={`${basePath}css/style.css`} />
    <title>{title}</title>
  </head>
  <body>
    {
      /* ページ遷移シャッター（斜めシアー・シアン2トーン）。覆う/見せるの
        制御は js/main.js と head のインラインスクリプト。 */
    }
    <div class="pt-shutter" aria-hidden="true">
      <span class="pt-shutter__panel pt-shutter__panel--back"></span>
      <span class="pt-shutter__panel pt-shutter__panel--front"></span>
    </div>
    <div class="pt-page">
      <slot />
    </div>
    <script src={`${basePath}js/main.js`} defer is:inline></script>
  </body>
</html>
