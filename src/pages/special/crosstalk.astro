---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import BottomCta from "../../components/BottomCta.astro";

const base = "../../";

const members = [
  {
    name: "M.J",
    dept: "開発部 電子開発科",
    year: "2023年入社",
    course: "人間科学部 人間科学研究科",
    photo: `${base}images/special/crosstalk/p01.png`,
  },
  {
    name: "Y.M",
    dept: "生産技術部",
    year: "2023年入社",
    course: "生物資源学部 共生環境学科",
    photo: `${base}images/special/crosstalk/p02.png`,
  },
  {
    name: "A.M",
    dept: "人事部",
    year: "2023年入社",
    course: "日本語日本文学科",
    photo: `${base}images/special/crosstalk/p03.png`,
  },
  {
    name: "N.H",
    dept: "製品販売促進部",
    year: "2023年入社",
    course: "都市科学部 環境リスク共生学科",
    photo: `${base}images/special/crosstalk/p04.png`,
  },
];

// コメントのアバターは参加メンバーの顔写真 p01〜p04.png（who: 1=M.J / 2=Y.M / 3=A.M / 4=N.H）
const avatarSrc = (n: number) => `${base}images/special/crosstalk/p0${n}.png`;
const sceneSrc = (name: string) =>
  `${base}images/special/crosstalk/${name}.png`;
const memberName = (n: number) => members[n - 1].name;

// Q&A 各セクション：q = 見出し、lead = 司会／インタビュアーの問い、
// items = 発言（who + body）または挿入画像（img）。順序は Figma 626:1206 の配置に準拠。
type QaComment = { who: number; body: string };
type QaScene = { img: string };
type QaItem = QaComment | QaScene;
type QaSection = { q: string; lead: string; items: QaItem[] };

const sections: QaSection[] = [
  {
    q: "まずは自己紹介から。今どんな仕事をしていて、どんな「やりがい」を感じていますか？",
    lead: "本日はよろしくお願いいたします。4人は同じ2023年入社ですが、配属された部署はそれぞれ違いますよね。まずは自己紹介を兼ねて、お一人ずつ、今どんな仕事をしているのかを教えてください。",
    items: [
      {
        who: 1,
        body: "開発部の電子開発課で、ロボットアーム付き洗浄機のシステムや、冷蔵庫内の温度などの製品データをクラウド上で扱うアプリの開発をしています。どちらもホシザキにとって新しい分野への挑戦で、自分で調べて考えながら答えを形にしていく過程にやりがいを感じています。",
      },
      {
        who: 2,
        body: "私は生産技術部で、治工具の設計や設備の導入・立ち上げ、試作品の製作、加工法の研究など、製品を効率よく高い品質でつくり続けるための「仕組み」づくりを担当しています。自分で設計した治工具や構想した設備が実際に形になっていく過程が、いちばんの面白さです。",
      },
      {
        who: 3,
        body: "私は人事部の採用係で、新卒採用に関わる業務全般を担当しています。毎年変化する採用市場に合わせて、自分の頭で考えて戦略を立て、企画していく仕事なので、挑戦できる機会が多いところにやりがいを感じています。",
      },
      {
        who: 4,
        body: "私は製品販売促進部で、新製品の提案資料づくりや勉強会などの販売促進支援と、市場ニーズの分析や仕様・価格の検討といった開発支援を担当しています。自分が関わった製品を街で見かけたときに、この仕事をやっていてよかったと実感します。",
      },
    ],
  },
  {
    q: "就活時のイメージと、入社後の「リアル」。ギャップはありましたか？",
    lead: "就職活動をしていた頃、ホシザキというと「製氷機や冷蔵庫のメーカー」というイメージを持っていた方も多いと思います。実際に入社してみて、仕事内容や会社の雰囲気に「思っていたのと違った」というギャップはありましたか。良い意味でも、そうでなくても、率直に聞かせてください。",
    items: [
      {
        who: 1,
        body: "僕はギャップがありました。世界でも競争力のある厨房機器メーカーで、「トップ企業＝常に最先端のものに囲まれている」というイメージで入ったんです。でも実際は、最先端は誰かが用意してくれるものではなくて、自分たちで生み出していくものだった。最初は少しギャップを感じましたが、今はそこにいちばん魅力を感じています。あと、僕はもともと開発畑の出身ではないんですが、設計の0から10まで一通り携われて。大変さはありますけど、周りの方が手厚くサポートしてくれるので、安心して取り組めています。",
      },
      {
        who: 2,
        body: "私はまさに、冷蔵庫や製氷機のメーカーという印象が強くて。堅実で安定した企業だな、と思っていました。でも入社してから、真空マイクロ波解凍庫のような製品まで開発していると知って。「こんな製品もつくっていたんだ」と、新しいものを次々に生み出している会社なんだなと感じました。それに驚いたのが、新製品へのこだわりと、開発から発売までのスピード感です。設計と設備の準備が同時並行で進むこともあって、「こんなテンポで動くんだ」と。挑戦し続けている会社なんだな、と感じました。あと、生産技術というと職人肌で黙々と作業するイメージだったんですが、実際は他部署との関わりも多くて、コミュニケーションが活発で。優しい方が多くて、困っていると先輩から声をかけてくださるので、本当に助かっています。",
      },
      {
        who: 3,
        body: "私は「業界No.1のリーディングカンパニー」「安定」「穏やかな社風」というイメージでした。社風については、入ってからもイメージ通りで。ただ一つ変わったのは、「安定しているからこそ、挑戦ができる会社なんだ」という認識ですね。それから、製品ラインナップの幅広さには驚かされました。今でも新しい製品が出るたびに、わくわくしています。",
      },
      {
        who: 4,
        body: "私も近くて、「業界No.1」と「温かい社風」という印象でした。面接を通じて社員の方の温かさを感じたことが、入社の決め手の一つでもあって。実際に入ってからも、周りに気にかけてくれる方が多くて、そのイメージとのギャップはまったくなかったです。",
      },
      {
        who: 3,
        body: "その「温かさ」は、外から見ているだけだと意外と伝わりにくい部分かもしれないですね。",
      },
      { img: "01" },
    ],
  },
  {
    q: "若手の意見は言いやすい？ 「ホシザキらしいチームワーク」を感じたエピソードは？",
    lead: "今、「温かさ」という言葉が出ましたが、もう少し具体的に伺えますか。若手の意見は言いやすい環境でしょうか。上司や先輩、他部署の方との関わりの中で、「ホシザキって、いいチームだな」と感じた場面があれば、エピソードで教えてください。",
    items: [
      {
        who: 1,
        body: "困っていると、別の部署の人でも「どうした？」と自然に声をかけてくれるんです。だから相談のハードルがすごく低くて。印象に残っているのは、食器消毒保管庫のモデルチェンジに、若手中心のチームで取り組んだときですね。いろいろな部署に相談しながら進めて、最後はチームで打ち上げまでできて。部署を越えて協力し合えたことに、ホシザキらしさを感じました。上司とは月に1回の面談があって、仕事のことはもちろん、キャリアやプライベートまで気軽に話せるのも、ありがたいところです。",
      },
      {
        who: 2,
        body: "それ、私もすごく感じます。入社してすぐに設備案件を引き継いだときは本当に不安だったんですが、係長や課長だけじゃなくて、他部署の方まで「大丈夫？」と気にかけてくれて。若手でも意見を言いやすいんですよね。何か相談すると、まず「山岡さんはどう思う？」と聞いてくれて、そのうえで「だったら、こうした方がいいかもね」とアドバイスをくれる。自分で考える余白を残してくれるのが、本当にありがたいなと思います。",
      },
      {
        who: 3,
        body: "分かります。私の場合は、役職者の方とかかわる仕事もあり、最初は緊張しましたが、皆さんフラットに接してくださるのを感じます。部署だけでなく、年齢や立場を越えてコミュニケーションが取りやすい雰囲気があります。",
      },
      {
        who: 4,
        body: "販売促進課は、一人ひとりが担当機種を持つので、製品知識を深めながら、仕様を決める場面でも意見を出せるんです。開発支援では技術部門や販売会社、ときにはエンドユーザーとも連携します。いろいろな立場の意見を取り入れながら、より良い製品をつくり上げていく過程そのものに、ホシザキらしいチームワークを感じますね。",
      },
      {
        who: 1,
        body: "あと、僕たち同期は本当に仲が良くて、それもチームワークにつながっている気がします。入社して3年たった今でも食堂で一緒にお昼を食べていますし、プライベートでも年に1度、バーベキューに行ったりしているんですよ。同期のつながりがあるからこそ、同期がいる部署との仕事がしやすくなったり、お昼の他愛もない話でリフレッシュできたりしているので、とても貴重な存在だと思います。",
      },
      {
        who: 2,
        body: "新入社員研修を一緒に過ごす中で、自然と仲が深まりましたよね。2年目・3年目の研修では、お互いの成長を称え合ったり、刺激をもらったりしながら、部署は違っても、ともに成長してきたなと実感しています。",
      },
      { img: "03" },
    ],
  },
  {
    q: "3年間で一番「成長できた」仕事は？ そして、これから挑戦したいことは？",
    lead: "入社して3年。振り返って、「これで成長できた」「大きく挑戦できた」と感じる仕事は何でしたか。そして、その経験を踏まえて、これからホシザキでどんなことに挑戦していきたいか、今の目標もあわせて聞かせてください。",
    items: [
      {
        who: 1,
        body: "僕は、食器消毒保管庫のモデルチェンジで、社内規定や法律への適合確認に携わった仕事です。法律の知識はほとんどなかったので、いろいろな方に相談して、自分でも調べながら理解を深めていきました。その結果、不適合につながる可能性のある部分を事前に見つけて、問題を未然に防ぐことができた。あのときの達成感は大きかったですね。もともと違う分野を学んできた人間が、こうして開発の現場で形を残せたことが、自分の自信になっています。最近は部署内で「AIを製品にどう取り入れていくか」という話も出ているので、これからはAIを活用した新しい製品開発にも関わっていきたいですね。ゆくゆくは、設計と電子の両方を経験してきた強みを生かして、自分でゼロから考えた製品やサービスを形にするのが夢です。",
      },
      {
        who: 2,
        body: "私は、新しい生産ラインの設備立ち上げを任されたことです。試作の段階から関わって、設備の仕様決めから、導入後の立ち上げ、品質確認まで、一連の流れを担当しました。自分の決断が製品の品質と生産性を左右するという責任感と面白さを、強く感じた仕事でした。初めてメインで担当した設備で、不安でいっぱいでしたが、なんとか生産に間に合わせることができて。技術者として一歩成長できたと思っています。これからは、工程改善や新規ラインの立ち上げに主体的に関わって、「山岡に聞けば大丈夫」と頼られる存在になりたいです。それに、生産技術はまだ女性が少ない部署なので、長く活躍できるロールモデルになれたら、という想いもあります。",
      },
      {
        who: 3,
        body: "すてきですね。",
      },
      {
        who: 4,
        body: "うん、かっこいいです。",
      },
      { img: "04" },
      {
        who: 3,
        body: "私は人を相手にする仕事なので、計画通りに進めるだけでなく、状況に応じて最適な選択をする柔軟性が身についたと思います。今後は国内にとどまらず、グローバルな仕事にも挑戦してみたいです。",
      },
      {
        who: 4,
        body: "私はやはり、新製品の屋外用冷蔵庫・冷凍庫を担当したことです。開発の検討段階からリリースまで携わりました。新製品なので、市場のニーズや求められる仕様を把握するために、市場調査や関係者へのヒアリングを数多く重ねて。開発部門や販売会社など、多くの関係者と連携しながら進める必要があって、その中で調整力や発信力が身についたと感じています。これからは、市場のニーズを的確に捉えて、より多くのお客様に喜んでいただける製品づくりと販促に携わっていきたいです。",
      },
    ],
  },
  {
    q: "福利厚生や働きやすさは、実際どうですか？",
    lead: "長く働き続けるうえでは、制度や環境の充実も気になるところだと思います。福利厚生や働きやすさの面で、「これは助かっている」「ホシザキのいいところだな」と実感していることを、本音で教えてください。",
    items: [
      {
        who: 2,
        body: "本社の敷地内に社員食堂があって、私はよく利用しています。メニューが豊富で、好きなおかずや麺、デザートまで気分に合わせて選べるので、毎回選ぶのが楽しみで。育休についても、出産後に復帰されている女性社員の方が多い印象があります。リロクラブでは、映画のチケットが特別料金で買えて、定価の半額くらいになることもありますし、宿泊施設や飲食店の割引もあって便利ですよ。",
      },
      {
        who: 3,
        body: "食堂は食事補助も出ているので、本当に安いんです。麺類なら一杯400円以下で、よく食べる同期でも700円あればおなかいっぱいだと言っていました。しかも安いだけじゃなくて、おいしくて。季節限定や多国籍のメニューもあって、そこもお気に入りです。",
      },
      {
        who: 4,
        body: "私は、入社してしばらく会社の寮を利用していました。光熱費込みで月1万5千円ほどで住めたので、社会人になりたての頃は本当に助かりました。リロクラブで、飲食店や映画館をお得に使えたり、メガネを割引価格で買えたりもします。有給休暇も取りやすくて、自分の予定に合わせて柔軟に休めるのは、働きやすさにつながっていますね。",
      },
      {
        who: 1,
        body: "僕も出身が愛知ではないので、寮に入っています。最近建て直したそうで、室内はホテルのようできれいなんですよ。何より安くて、会社からも近い。リロクラブの割引はまだ映画くらいでしか使えていないので、これからいろいろ活用していきたいです。あと、うちの上司は女性で時短勤務していますが、そういう働き方をしてもキャリアにまったく影響がない。そこは本当にいいなと思います。",
      },
      {
        who: 3,
        body: "そうなんですよね。子育てしながら活躍している女性社員も多いので、とても憧れます。しかも男性社員もほとんどの方が育休を取得しているので、制度を利用しやすい雰囲気があるのはいいですよね。",
      },
    ],
  },
  {
    q: "それでは最後に、学生の皆さんへメッセージをお願いします。",
    lead: "",
    items: [
      {
        who: 1,
        body: "ホシザキは、僕のように異なる分野を学んできた人間でも、先輩や上司が優しくサポートしてくれる、風通しのいい会社です。若手でも挑戦させてもらえますし、困ったときは必ず周りがフォローしてくれます。新しいことに前向きに取り組んで、周囲と協力しながら成長したい方と、ぜひ一緒に挑戦していきたいです。",
      },
      {
        who: 2,
        body: "就職活動では不安なことも多いと思いますが、ホシザキには、周囲が自然と助け合う温かい風土があります。会社の雰囲気は、実際に話を聞いたり、選考を受けたりする中で見えてくる部分も大きいので、まずはいろいろな会社を見てみてください。その選択肢の一つにホシザキがいてくれたら、うれしいです。自分らしさを大切に、前向きにチャレンジしてくださいね。",
      },
      {
        who: 3,
        body: "就職活動は大変なこともありますが、じっくり自分と向き合える貴重な機会でもあります。価値観は時間とともに変わることもあるので、ぜひ広い視野で情報を集めてみてください。そして、就職活動はご縁でもあります。企業に対して感じた直感やフィーリングも、ぜひ大切にしてほしいです。ホシザキは外から見ると「大企業」ですが、中はとてもアットホームなので、その空気感を直接感じに来ていただけたらうれしいです。",
      },
      {
        who: 4,
        body: "業績の安定感もありますが、それ以上に、働く人の雰囲気が温かい会社です。仕事の内容だけでなく、「どんな人と働くか」も、私はとても大切だと感じています。ホシザキには、周囲と協力しながら挑戦できる環境があるので、安心して成長できると思います。ぜひ一度、実際に社員と話して、会社の雰囲気を感じてみてください。一緒に働ける日を、楽しみにしています。",
      },
    ],
  },
];
---

<Layout
  basePath={base}
  title="若手が語るはたらく環境｜クロストーク｜ホシザキ本社採用サイト"
  description="入社3年目を迎えた若手社員によるクロストーク。入社前後のギャップ、若手の意見が尊重される風土、チームワーク、そしてこれから叶えたいキャリアを語ります。"
>
  <div class="l-container">
    <Header basePath={base} />
    <main class="l-main">
      <article class="p-crosstalk">
        <section class="p-crosstalk__hero">
          <div class="p-crosstalk__hero-inner">
            <figure class="p-crosstalk__kv">
              <img
                src={`${base}images/special/crosstalk/kv.png`}
                alt="社員4名がテーブルを囲んで談笑するクロストークの様子"
                loading="eager"
              />
            </figure>
            <div class="p-crosstalk__hero-head">
              <p class="p-crosstalk__kicker"><span>クロストーク</span></p>
              <h1 class="p-crosstalk__title">
                <span class="p-crosstalk__title-text"
                  >若手が語るはたらく環境</span
                >
              </h1>
            </div>
            <div class="p-crosstalk__hero-body">
              <p class="p-crosstalk__subtitle">
                常識を跳び越え、高め合う。入社3年目が語るホシザキの『リアル』と『チームワーク』
              </p>
              <div class="p-crosstalk__lead">
                <p>
                  「厨房機器メーカー」という枠組みを跳び越え、世界中の「食」を支えるインフラ企業へと進化を続けるホシザキ。<br
                  />そこでは一体どんな人たちが、どのような想いで働いているのでしょうか？
                </p>
                <p>
                  今回は入社3年目を迎えた若手社員4名が集結。入社前に抱いていたイメージと現実のギャップ、若手の意見が尊重される風土、<br
                  />そして壁を乗り越えて実感した自らの成長まで、等身大の言葉で語り合います。
                </p>
                <p>
                  「常識の先へ、跳べ」――。未知の海へ漕ぎ出す“ファーストペンギン”たちのリアルな日常と、支え合うチームの絆を覗いてみてください。<br
                  />あなたの未来を切り拓くヒントが、ここにあるはずです。
                </p>
              </div>
            </div>
          </div>
        </section>

        <section class="p-crosstalk__members" aria-label="参加メンバー">
          <div class="p-crosstalk__members-panel">
            <p class="p-crosstalk__members-badge">
              <span class="p-crosstalk__members-badge-shadow" aria-hidden="true"
              ></span>
              <span class="p-crosstalk__members-badge-face">
                <span class="p-crosstalk__members-badge-text">参加メンバー</span
                >
              </span>
            </p>
            <ul class="p-crosstalk__members-list">
              {
                members.map((m) => (
                  <li class="p-crosstalk__member">
                    <figure class="p-crosstalk__member-photo">
                      <img
                        src={m.photo}
                        alt={`${m.name}さんの顔写真`}
                        loading="lazy"
                      />
                    </figure>
                    <p class="p-crosstalk__member-name">{m.name}</p>
                    <p class="p-crosstalk__member-dept">{m.dept}</p>
                    <p class="p-crosstalk__member-meta">
                      <span>{m.year}</span>
                      <span>{m.course}</span>
                    </p>
                  </li>
                ))
              }
            </ul>
          </div>
        </section>

        <div class="p-crosstalk__body">
          {
            sections.map((block) => (
              <section class="p-crosstalk__qa">
                <h2 class="p-crosstalk__q">{block.q}</h2>
                {block.lead && <p class="p-crosstalk__lead-q">{block.lead}</p>}
                <div class="p-crosstalk__stream">
                  {block.items.map((item) =>
                    "img" in item ? (
                      <figure class="p-crosstalk__scene">
                        <img src={sceneSrc(item.img)} alt="" loading="lazy" />
                      </figure>
                    ) : (
                      <div class="p-crosstalk__comment">
                        <figure class="p-crosstalk__comment-avatar">
                          <img
                            src={avatarSrc(item.who)}
                            alt={`${memberName(item.who)}さん`}
                            loading="lazy"
                          />
                        </figure>
                        <p class="p-crosstalk__comment-body">{item.body}</p>
                      </div>
                    ),
                  )}
                </div>
              </section>
            ))
          }
        </div>

        <p class="p-crosstalk__cta">
          <a href={`${base}special/`} class="p-crosstalk__cta-link">
            スペシャルコンテンツ一覧を見る
            <span class="p-crosstalk__cta-icon" aria-hidden="true">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="3"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <polyline points="9 6 15 12 9 18"></polyline>
              </svg>
            </span>
          </a>
        </p>

        <BottomCta basePath={base} />
        <Breadcrumb
          basePath={base}
          items={[
            { href: `${base}special/`, label: "スペシャルコンテンツ" },
            { label: "若手が語るはたらく環境" },
          ]}
        />
      </article>
    </main>
    <Footer basePath={base} />
  </div>
</Layout>
