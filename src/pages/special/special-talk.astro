---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import BottomCta from "../../components/BottomCta.astro";

const base = "../../";

// 単独インタビュー（開発責任者）のため、アバターは全コメント共通
const avatar = `${base}images/special/sp03_pic01.png`;

const qa = [
  {
    q: "今では厨房の「当たり前」となった省エネ技術ですが、開発当時はどのような壁があったのでしょうか？",
    body: "最大の壁は「厨房という過酷な環境」そのものでした。高温多湿で油煙が舞う中、精密なインバータ基板をどう熱から守り、安定稼働させるか。単なるモーター制御の知識だけでは通用しません。私たちは筐体内の熱流体解析（CFD）を何度も繰り返し、空気の引き込みから排熱までの冷却構造を根本から設計し直しました。また、コンプレッサーの回転数を負荷に応じてミリ秒単位で最適化する独自のアルゴリズムを組み上げたことで、消費電力を劇的に下げることに成功したんです。当時は誰もやらない泥臭いアプローチでしたが、結果的にこの「極限環境での精密制御」が世界のスタンダードになりました。",
    image: `${base}images/special/special-talk/01.png`,
  },
  {
    q: "その「ゼロから創る」精神が、現在注力されている「真空マイクロ波解凍機」にも活きていると伺いました。この製品の凄さはどこにあるのでしょうか？",
    body: "物理現象のコントロールとして、非常に高度で面白いアプローチをしています。マイクロ波は対象物を内部から素早く温めますが、氷が水に変わった瞬間、そこだけ急激に電波を吸収して温度が上がる「熱暴走（加熱ムラ）」が起きてしまう。これを防ぐために「真空冷却」を掛け合わせました。 真空状態では水の沸点が極端に下がります。つまり、温まりすぎた部分の水分がすぐに蒸発し、その気化熱によって自ら冷却を行うんです。マイクロ波による「加熱」と、真空蒸発による「冷却」という相反するベクトルを、ミリバール単位の圧力制御とW（ワット）単位の出力制御で絶妙にバランスさせる。これにより、細胞組織を一切壊さずドリップを出さない完璧な解凍を実現しました。これは熱力学と電磁波工学の究極のミキシングだと言えます。",
    image: null,
  },
  {
    q: "なるほど、細胞レベルでの温度制御ができるのですね。そうした技術は、飲食業界以外にも応用が広がっているのでしょうか？",
    body: "ええ、「液体急速凍結機」もその一つです。マイナス35℃のエタノール溶液に食材を沈めて凍らせるのですが、空気の約20倍という液体の圧倒的な熱伝導率を利用しています。食品の細胞内の水分が凍る「最大氷結晶生成帯」という温度域をいかに一瞬で通過させるかが勝負で、流体力学を用いて庫内の溶液の撹拌流を最適化し、ムラなく全体を急速冷凍する機構を設計しました。 この「細胞を破壊せずに凍らせる・解凍する」という極限の温度制御技術は、医療分野における検体や血液の長期保存、あるいは農業・水産業のコールドチェーン構築など、社会インフラの根幹を支える技術に直結しています。私たちの主戦場は、すでに厨房の枠を越えているんです。",
    image: `${base}images/special/special-talk/02.png`,
  },
  {
    q: "高度な技術開発が進む中で、ホシザキの技術者に根付く「絶対に変わらないもの」は何でしょうか？",
    body: "「原理原則に立ち返る」ことです。ホシザキの開発は、既存の部品を組み合わせるアセンブリではありません。なぜ冷えないのか、なぜ壊れるのか、その答えは常に熱力学、流体力学、材料工学などの基礎物理の中にあります。 シミュレーション技術がどれだけ発達しても、私たちは実際にプロトタイプを組み、極限環境のテストルームで限界まで負荷をかけます。そこで得られた生のエラーデータこそが、次のブレイクスルーの種になる。この「現場での実証」に徹底的にこだわる泥臭さこそが、私たちの強みであり、ものづくりの哲学です。",
    image: `${base}images/special/special-talk/03.png`,
  },
  {
    q: "最後に、これから共に未来を創る学生の皆さんへメッセージをお願いします。",
    body: "ホシザキの製品開発は、機械設計、電気・電子制御、ソフトウェア、そして化学や物理まで、あらゆる理系分野の知識が総動員される総合格闘技です。「食」や「医療」の未来を変えるには、皆さんが大学や研究室で学んでいる専門知識が必ず武器になります。前例のない課題に対して、自分の頭で仮説を立て、実験し、今の常識の先へ跳躍する。そんな知的好奇心にあふれた皆さんと一緒に、世界を変えるモノづくりに挑戦したいですね。",
    image: null,
  },
];
---

<Layout
  basePath={base}
  title="ホシザキの技術が作る未来｜スペシャルトーク｜ホシザキ本社採用サイト"
  description="ホシザキの開発責任者による特別トーク。インバータ制御技術から真空マイクロ波解凍機まで、常識を疑い次の常識を創る開発の醍醐味と、食・医療の未来を変えるものづくりへのビジョンを語ります。"
>
  <div class="l-container">
    <Header basePath={base} />
    <main class="l-main">
      <article class="p-special-talk">
        <section class="p-special-talk__hero">
          <div class="p-special-talk__hero-inner">
            <figure class="p-special-talk__kv">
              <img
                src={`${base}images/special/special-talk/kv.png`}
                alt="腕を組んで佇むホシザキの開発責任者"
                loading="eager"
              />
            </figure>
            <div class="p-special-talk__hero-head">
              <p class="p-special-talk__kicker"><span>スペシャルトーク</span></p>
              <h1 class="p-special-talk__title">
                <span class="p-special-talk__title-text">ホシザキの技術が作る未来</span>
              </h1>
            </div>
            <div class="p-special-talk__hero-body">
              <p class="p-special-talk__subtitle">
                ホシザキの開発責任者による特別トーク
              </p>
              <div class="p-special-talk__lead">
                <p>
                  業界で初めて業務用冷蔵庫への「インバータ制御技術」を実用化し、現在の厨房における「省エネの当たり前」を創り上げた立役者。この技術は今や世界の標準仕様となっている。数々の特許を取得後、現在は次世代コア技術となる自然冷媒システムや「真空マイクロ波解凍機」などの先端研究を総括。「常識を疑い、次の常識を創る」開発の醍醐味と未来へのビジョンを語る。
                </p>
              </div>
            </div>
          </div>
        </section>

        <div class="p-special-talk__body">
          {
            qa.map((block) => (
              <section class="p-special-talk__qa">
                <h2 class="p-special-talk__q">{block.q}</h2>
                <div class="p-special-talk__comment">
                  <figure class="p-special-talk__comment-avatar">
                    <img src={avatar} alt="" loading="lazy" />
                  </figure>
                  <p class="p-special-talk__comment-body">{block.body}</p>
                </div>
                {block.image && (
                  <figure class="p-special-talk__scene">
                    <img src={block.image} alt="" loading="lazy" />
                  </figure>
                )}
              </section>
            ))
          }
        </div>

        <p class="p-special-talk__cta">
          <a href={`${base}special/`} class="p-special-talk__cta-link">
            スペシャルコンテンツ一覧を見る
            <span class="p-special-talk__cta-icon" aria-hidden="true">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="3"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <polyline points="9 6 15 12 9 18"></polyline>
              </svg>
            </span>
          </a>
        </p>

        <BottomCta basePath={base} />
        <Breadcrumb
          basePath={base}
          items={[
            { href: `${base}special/`, label: "スペシャルコンテンツ" },
            { label: "ホシザキの技術が作る未来" },
          ]}
        />
      </article>
    </main>
    <Footer basePath={base} />
  </div>
</Layout>
