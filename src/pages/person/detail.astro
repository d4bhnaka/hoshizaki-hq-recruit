---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import BottomCta from "../../components/BottomCta.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";

const base = "../../";

interface Interview {
  question: string;
  answer: string;
}

const sample =
  "テキストサンプルテキストサンプルテキストサンプルテキストサンプルテキストサンプルテキストサンプルテキストサンプルテキストサンプルテキストサンプルテキストサンプルテキストサンプルテキストサンプルテキストサンプル。";

const interviews: Interview[] = [
  {
    question: "ホシザキに入ったきっかけは？",
    answer: "世界の「食」を支える仕事内容に惹かれました",
  },
  {
    question: "やりがいを感じることは？",
    answer: "最新技術に対応するには自分自身の知識と技量のアップデートが必要",
  },
  {
    question: "今後の目標は？",
    answer: "技術、知識、会話力 すべてを兼ね備えた信頼される技術者になりたい",
  },
  {
    question: "学生へのメッセージ",
    answer: "失敗を恐れず、何事もチャレンジしてみてください！",
  },
];
---

<Layout
  basePath={base}
  title="S.T ／ 技術サービス｜ホシザキ本社採用サイト"
  description="ホシザキ本社の先輩社員インタビュー。技術サービス職 S.T（2018年入社）が語る、ホシザキで働く理由と技術者としての挑戦。"
>
  <div class="l-container">
    <Header basePath={base} />
    <main class="l-main">
      <article class="p-person-detail">
        <!-- Split layout: left scroll content, right sticky photo -->
        <section class="p-person-detail__split">
          <div class="p-person-detail__left">
            <p class="p-person-detail__label">Person</p>
            <h1 class="p-person-detail__title">
              ペンギンマークの会社で<br />
              働いています！と<br />
              自信をもって言える事
            </h1>

            <div class="p-person-detail__meta">
              <span class="p-person-detail__meta-name">S.T</span>
              <span class="p-person-detail__meta-sep" aria-hidden="true">／</span>
              <span class="p-person-detail__meta-item">技術サービス</span>
              <span class="p-person-detail__meta-sep" aria-hidden="true">／</span>
              <span class="p-person-detail__meta-item">2018年入社</span>
              <span class="p-person-detail__meta-sep" aria-hidden="true">／</span>
              <span class="p-person-detail__meta-item">理系卒</span>
            </div>

            <div class="p-person-detail__interviews">
              {
                interviews.map((iv) => (
                  <div class="c-interview-block">
                    <p class="c-interview-block__question">
                      <span class="c-interview-block__dash" aria-hidden="true">——</span>
                      {iv.question}
                    </p>
                    <h2 class="c-interview-block__answer">{iv.answer}</h2>
                    <div class="c-interview-block__body">
                      <p class="c-interview-block__paragraph">{sample}</p>
                      <p class="c-interview-block__paragraph">{sample}</p>
                    </div>
                  </div>
                ))
              }
            </div>
          </div>

          <aside class="p-person-detail__right">
            <div class="p-person-detail__sticky">
              <figure class="p-person-detail__photo">
                <img
                  src={`${base}images/person/detail-main.jpg`}
                  alt="S.T"
                  loading="lazy"
                />
              </figure>
              <p class="p-person-detail__annotation">
                ↑画像が固定され、左側だけスクロールします
              </p>
            </div>
          </aside>
        </section>

        <!-- Back to list button -->
        <div class="p-person-detail__back">
          <a class="p-person-detail__back-btn" href="../">
            <span class="p-person-detail__back-label">社員インタビュー一覧を見る</span>
            <span class="p-person-detail__back-chevron" aria-hidden="true">›</span>
          </a>
        </div>

        <!-- Bottom CTA -->
        <BottomCta basePath={base} />

        <!-- Breadcrumb -->
        <div class="p-person-detail__breadcrumb">
          <Breadcrumb
            basePath={base}
            items={[{ label: "はたらく人を知る", href: "../" }, { label: "S.T" }]}
          />
        </div>
      </article>
    </main>
    <Footer basePath={base} />
  </div>
</Layout>
