---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/PageHero.astro";
import BottomCta from "../components/BottomCta.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import PersonCard from "../components/PersonCard.astro";

const base = "../";

const filters = [
  { label: "すべて", value: "all", active: true },
  { label: "技術系", value: "tech" },
  { label: "企画管理系", value: "admin" },
  { label: "理系", value: "science" },
  { label: "文系", value: "humanities" },
  { label: "男性", value: "male" },
  { label: "女性", value: "female" },
];

interface PersonCard {
  image: string;
  quote: string;
  body: string;
  department: string;
  tags: string[];
}

const firstRow: PersonCard[] = [
  {
    image: `${base}images/person/person-01.jpg`,
    quote: "最新技術を学べて、プロフェッショナルとして成長できる！",
    body: "ペンギンマークの会社で／働いています！と／自信をもって言える事",
    department: "開発設計職",
    tags: ["tech", "science", "male"],
  },
  {
    image: `${base}images/person/person-02.jpg`,
    quote: "世界を相手に「食のインフラ」を届ける醍醐味があります。",
    body: "ペンギンマークの会社で／働いています！と／自信をもって言える事",
    department: "海外事業企画・海外営業",
    tags: ["admin", "humanities", "female"],
  },
  {
    image: `${base}images/person/person-03.jpg`,
    quote: "お客様の現場に立ち、本当に求められる営業提案を。",
    body: "ペンギンマークの会社で／働いています！と／自信をもって言える事",
    department: "国内広域営業・営業企画",
    tags: ["admin", "humanities", "male"],
  },
  {
    image: `${base}images/person/person-04.jpg`,
    quote: "人と組織の成長を支える、縁の下の力持ち。",
    body: "ペンギンマークの会社で／働いています！と／自信をもって言える事",
    department: "コーポレート",
    tags: ["admin", "humanities", "female"],
  },
];

const serviceQuotes = [
  "最新技術を学べて、プロフェッショナルとして成長できる！",
  "お客様の「助かった」の一言が、何よりのやりがい。",
  "現場で培った知識が、そのまま自分の強みになる。",
  "仲間と助け合いながら、一台一台に責任を持つ。",
  "毎日違う現場で、新しい発見と出会える仕事。",
  "ペンギンマークに込められた信頼を、自分の手で届ける。",
  "技術者として、一生磨き続けられる仕事がある。",
  "お客様の笑顔が、次の一歩への原動力になる。",
  "どんなトラブルも「解決できた！」の達成感に変わる。",
  "世界中の「食」を支える現場で、誇りをもって働ける。",
];

const serviceCards: PersonCard[] = serviceQuotes.map((quote, i) => ({
  image: `${base}images/person/person-${String(i + 5).padStart(2, "0")}.jpg`,
  quote,
  body: "ペンギンマークの会社で／働いています！と／自信をもって言える事",
  department: "技術サービス",
  tags: ["tech", i % 2 === 0 ? "science" : "humanities", i % 3 === 0 ? "female" : "male"],
}));

const cards: PersonCard[] = [...firstRow, ...serviceCards];
---

<Layout
  basePath={base}
  title="はたらく人を知る｜ホシザキ本社採用サイト"
  description="ホシザキで働く先輩社員たちの声を紹介。「ここに決めた！」理由と、入社後のリアルなストーリーを職種別に掲載しています。"
>
  <div class="l-container">
    <Header basePath={base} />
    <main class="l-main">
      <article class="p-person">
        <PageHero en="Person" ja="はたらく人を知る" variant="cloud">
          <p class="p-person__catch">
            先輩たちの<span>「ここに決めた！」</span>
          </p>
        </PageHero>

        <!-- Filter tabs -->
        <section class="p-person__filter" aria-label="職種で絞り込み">
          <ul class="p-person__filter-list">
            {
              filters.map((f) => (
                <li class="p-person__filter-item">
                  <button
                    type="button"
                    class={`p-person__filter-btn${f.active ? " p-person__filter-btn--active" : ""}`}
                    data-person-filter={f.value}
                    aria-pressed={f.active ? "true" : "false"}
                  >
                    {f.label}
                  </button>
                </li>
              ))
            }
          </ul>
        </section>

        <!-- Person card grid -->
        <section class="p-person__grid-section" aria-label="社員一覧">
          <ul class="p-person__grid">
            {
              cards.map((card) => (
                <li
                  class="p-person__grid-item"
                  data-person-card
                  data-person-tags={card.tags.join(" ")}
                >
                  <PersonCard
                    image={card.image}
                    quote={card.quote}
                    body={card.body}
                    department={card.department}
                  />
                </li>
              ))
            }
          </ul>
        </section>

        <!-- Bottom CTA -->
        <BottomCta basePath={base} />

        <!-- Breadcrumb -->
        <div class="p-person__breadcrumb">
          <Breadcrumb basePath={base} items={[{ label: "はたらく人を知る" }]} />
        </div>
      </article>
    </main>
    <Footer basePath={base} />
  </div>
</Layout>
