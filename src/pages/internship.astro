---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import InternshipHeading from "../components/InternshipHeading.astro";
import CourseCard from "../components/CourseCard.astro";
import CourseDetail from "../components/CourseDetail.astro";
import type { Course } from "../components/CourseDetail.astro";

const base = "../";

// 「冒険を始める ENTRY」は外部の応募ページへ遷移。
const entryHref =
  "https://hoshizaki-corporation-hr.snar.jp/jobboard/detail.aspx?id=hNWzuuEY-h8";

const courses: Course[] = [
  {
    id: "course-01",
    title:
      "【理系】開発設計職5Daysインターンシップ（機械設計コース／制御設計コース）",
    image: "course-01.png",
    points: [
      {
        num: "01",
        title: "「1台丸ごと」を生み出す開発環境",
        body: "少人数チームで開発の「1から10まで」に携わり、歯車ではないものづくりの醍醐味を味わう。",
      },
      {
        num: "02",
        title: "最先端の開発拠点「中央研究所」が舞台",
        body: "プロが使用するCADシステムや試験室など、実際の開発環境で実務レベルの課題に没頭する。",
      },
      {
        num: "03",
        title: "開発設計の社員による個別フィードバック",
        body: "最終日の報告会では、現場で活躍する社員が学生一人ひとりに本気のフィードバックを実施。",
      },
    ],
    program: [
      {
        day: "DAY 1",
        title: "オリエンテーションと開発設計部門紹介",
        body: "会社紹介、工場・試験室見学、オリエンテーション",
      },
      {
        day: "DAY 2〜4",
        title: "設計開発・実務体験",
        body: "社員とのミーティング同席、実際の製品（製氷機や冷蔵庫など）の動作観察、図面作成、開発試験",
      },
      {
        day: "DAY 5",
        title: "振り返り報告とフィードバック",
        body: "実習の振返り、成果報告会、現場社員（若手〜マネジメント層）からの個別フィードバック",
      },
    ],
    programOverview: [
      {
        label: "対象",
        value: [
          "理系学生（学部・学科不問／基礎的なOffice操作ができる方）",
          "で、機械やものづくりに興味がある方",
        ],
      },
      { label: "開催時期", value: ["8月〜9月の平日5日間"] },
      { label: "会場", value: ["愛知本社（中央研究所） または", "島根工場"] },
      {
        label: "待遇",
        value: [
          "交通費実費支給",
          "宿泊手配あり（遠方者）",
          "昼食代支給（社員食堂利用可）",
        ],
      },
      {
        label: "選考",
        value: ["マイページよりES提出 → WEB面接（1回） → 参加決定"],
      },
    ],
    voices: [
      {
        avatar: "voice-01.png",
        text: "用意されたワークではなく、実際に開発設計の業務を体験できたため、新入社員として配属されたような気分で参加することができ、貴社で働くイメージを具体的にもつことができました。",
      },
      {
        avatar: "voice-02.png",
        text: "設計者の思いがそのまま製品としてユーザーに届けられる、完成品メーカーでならではのやりがいを感じられる開発環境が魅力的だと感じました。",
      },
      {
        avatar: "voice-03.png",
        text: "課内の方とのコミュニケーションをとる機会が多くあり、働くイメージを明確にすることができました。",
      },
      {
        avatar: "voice-04.png",
        text: "データ整理や結果の議論など、大学での研究で得た技能・経験がメーカーでの業務に生きることを体感できました。",
      },
    ],
  },
  {
    id: "course-02",
    title: "【理系】2Days仕事体験　工場技術コース（愛知本社）",
    image: "course-02.png",
    points: [
      {
        num: "01",
        title: "生産現場の課題解決を実践ワークで体感できる",
        body: "多品種少量生産を実現するセル生産方式の現場に入り、量産設計と現場改善の最前線を体感する。",
      },
      {
        num: "02",
        title: "ホシザキブランドの品質を守る品質保証の仕事をリアルに体感",
        body: "ロボティクスやIoTを活用した最新の製造ラインで、生産技術エンジニアの課題解決プロセスを学ぶ。",
      },
      {
        num: "03",
        title: "現場社員との距離の近さ",
        body: "2日間を通じて若手からベテランまで多くの社員と関わり、リアルな働き方とキャリア像をつかむ。",
      },
    ],
    program: [
      {
        day: "DAY 1",
        title: "生産技術　体験ワーク",
        body: "会社紹介、仕事体験（工程設計、設備設計 等）、生産技術職場見学、社員座談会",
      },
      {
        day: "DAY 2",
        title: "品質保証　体験ワーク",
        body: "仕事体験（部品検査、製品認定 等）、品質保証職場見学、社員座談会",
      },
    ],
    programOverview: [
      {
        label: "対象",
        value: ["理系学生（学部・学科不問）"],
      },
      { label: "開催時期", value: ["8月〜9月の平日2日間"] },
      { label: "会場", value: ["愛知本社（工場・生産技術部門）"] },
      {
        label: "待遇",
        value: [
          "交通費実費支給",
          "宿泊補助あり（遠方者）",
          "昼食代支給（社員食堂利用可）",
        ],
      },
      {
        label: "選考",
        value: ["マイページよりES提出 → WEB面接（1回） → 参加決定"],
      },
    ],
    voices: [
      {
        avatar: "voice-02.png",
        text: "生産技術、品質保証いずれも、業務体験や職場見学があり、とても良かった。業務や会社の雰囲気を直接体感することはオンラインのプログラムではできないため、今回のプログラムに参加できてとても良かったです。",
      },
      {
        avatar: "voice-01.png",
        text: "工場の価値を最大化する生産技術部門の重要性を理解できました。また、新製品の準備から設備保全まで幅広く関わり、現場を支える役割の大きさを実感できた点が特に良かったです。",
      },
      {
        avatar: "voice-04.png",
        text: "若手社員の方からフランクにお話を伺えたことが特に良かったです。就活の軸や面接の雰囲気など包み隠さず教えていただき、今後就職活動を進めていく上で非常に勉強になりました",
      },
      {
        avatar: "voice-03.png",
        text: "品質保証が「ホシザキブランド」を支える重要な役割であることを実感しました。そして、グループワークではお客様目線を重視した改善策を考え、品質保証の視点を体験的に理解できた点が特に良かったです。",
      },
    ],
  },
  {
    id: "course-03",
    title: "【理系】1Day仕事体験　電子設計コース（WEB）",
    image: "course-03.png",
    points: [
      {
        num: "01",
        title: "製品を動かす「頭脳」を設計する",
        body: "製氷機や冷蔵庫の制御を担う電子回路・組込みソフトの開発を、第一線のエンジニアと体験する。",
      },
      {
        num: "02",
        title: "WEBで気軽に参加できる1Day",
        body: "全国どこからでも参加可能。電子設計職の仕事内容と求められる素養を短時間で理解できる。",
      },
      {
        num: "03",
        title: "現役エンジニアによる解説",
        body: "実際の開発事例をもとに、回路設計から評価までの流れを現役社員がわかりやすく解説する。",
      },
    ],
    program: [
      {
        day: "AM",
        title: "会社・職種紹介",
        body: "会社紹介、電子設計職の役割と開発事例の紹介、エンジニアによるトークセッション",
      },
      {
        day: "PM",
        title: "社員座談会",
        body: "簡単な回路・制御をテーマにしたグループワーク、社員への発表と質疑応答",
      },
    ],
    programOverview: [
      {
        label: "対象",
        value: ["理系学生（電気電子系、情報工学系 専攻の方）"],
      },
      { label: "開催時期", value: ["8月〜9月のうち1日（WEB開催）"] },
      { label: "会場", value: ["オンライン（Zoom など）"] },
      { label: "待遇", value: ["オンライン開催のため費用負担なし"] },
      { label: "選考", value: ["マイページよりエントリー → 参加決定"] },
    ],
    voices: [
      {
        avatar: "voice-03.png",
        text: "アイデアを出す力やグループ内の意見をすり合わせるコミュニケーション能力を養うことができたと感じました。また、ワーク後にフィードバックがあったのも非常に学びになりました。",
      },
      {
        avatar: "voice-04.png",
        text: "社員の方々が実際にどのように考え、対策を行っているのか、電子設計者の視点を知ることができ、大変学びになりました。",
      },
      {
        avatar: "voice-01.png",
        text: "ワークの内容だけでなく、電子設計社員との座談会を通して実際の業務内容の詳細をうかがえたのが大変良かったです。",
      },
      {
        avatar: "voice-02.png",
        text: "ホシザキの電子設計業務についての具体的なイメージを掴むことができました。特に、システム構想から電子回路・ソフト設計まで一貫して携われる点が魅力的だと感じました。",
      },
    ],
  },
  {
    id: "course-04",
    title: "【理系】1Day仕事体験　機械設計コース（WEB）",
    image: "course-04.png",
    points: [
      {
        num: "01",
        title: "「冷やす」を形にする機械設計",
        body: "熱・流体・構造を踏まえた筐体や機構の設計プロセスを、第一線の機械設計者と体験する。",
      },
      {
        num: "02",
        title: "WEBで完結する1Dayプログラム",
        body: "全国どこからでも参加可能。機械設計職の役割と、ホシザキのものづくりの考え方を短時間で理解できる。",
      },
      {
        num: "03",
        title: "CADと設計思想を学ぶ",
        body: "実際の製品を題材に、設計者がどのような思考で形を決めているのかを具体的に学ぶ。",
      },
    ],
    program: [
      {
        day: "AM",
        title: "会社・職種紹介",
        body: "会社紹介、機械設計職の役割と開発事例の紹介、エンジニアによるトークセッション",
      },
      {
        day: "PM",
        title: "社員座談会",
        body: "身近な製品をテーマにした機構・構造のグループワーク、社員への発表と質疑応答",
      },
    ],
    programOverview: [
      {
        label: "対象",
        value: ["理系学生（学部・学科不問）"],
      },
      { label: "開催時期", value: ["8月〜9月のうち1日（WEB開催）"] },
      { label: "会場", value: ["オンライン（Zoom など）"] },
      { label: "待遇", value: ["オンライン開催のため費用負担なし"] },
      { label: "選考", value: ["マイページよりエントリー → 参加決定"] },
    ],
    voices: [
      {
        avatar: "voice-04.png",
        text: "普段目にするホシザキ製品を題材としたワーク。設計の工夫の一部を知ることで、製品全体としてはどれほどのアイデアが詰まっているのかさらに興味を持った。",
      },
      {
        avatar: "voice-02.png",
        text: "グループワークでは一人ひとりの意見を尊重し、議論を重ねて一つのアイデアにまとめるチームワークの重要性も学ぶことができました。",
      },
      {
        avatar: "voice-03.png",
        text: "多くの要素を緻密に計算する姿勢を肌で感じ、エンジニアとして深く追求したいという思いが強くなりました。",
      },
      {
        avatar: "voice-01.png",
        text: "チームで考えたプランに対して技術者の方からのフィードバックやアドバイスがもらえ、実際の仕事のような感覚を味わうことができた。",
      },
    ],
  },
];
---

<Layout
  basePath={base}
  title="インターンシップ｜ホシザキ本社採用サイト"
  description="ホシザキのインターンシップ情報。日本初の全自動製氷機を生み出した開発現場で、ものづくりの手触り感を体感するプログラムを紹介します。"
>
  <link
    slot="head"
    rel="stylesheet"
    href={`${base}css/swiper-bundle.min.css`}
  />
  <script slot="head" src={`${base}js/swiper-bundle.min.js`} defer is:inline
  ></script>

  <div class="l-container">
    <Header
      basePath={base}
      logoSrc={`${base}images/internship/internship-logo.png`}
    />
    <main class="l-main">
      <article class="p-internship">
        <!-- Hero -->
        <section
          class="p-internship-hero"
          aria-labelledby="internship-hero-title"
        >
          <div class="p-internship-hero__media" aria-hidden="true">
            <div class="p-internship-hero__track">
              <img src={`${base}images/internship/hero-collage.jpg`} alt="" />
              <img src={`${base}images/internship/hero-collage.jpg`} alt="" />
            </div>
          </div>
          <div class="p-internship-hero__overlay" aria-hidden="true"></div>
          <img
            class="p-internship-hero__ice p-internship-hero__ice--a"
            src={`${base}images/internship/ice-cubes-02.png`}
            alt=""
            aria-hidden="true"
          />
          <img
            class="p-internship-hero__ice p-internship-hero__ice--b"
            src={`${base}images/internship/ice-cubes-01.png`}
            alt=""
            aria-hidden="true"
          />
          <img
            class="p-internship-hero__penguin"
            src={`${base}images/internship/penguin-hero.png`}
            alt=""
            aria-hidden="true"
          />
          <h1
            class="p-internship-hero__title"
            id="internship-hero-title"
            data-inview="fade"
          >
            <img
              src={`${base}images/internship/main-copy.png`}
              alt="常識の先へ、一歩。未知の自分に、跳びこもう。"
            />
          </h1>
        </section>

        <!-- Hero scroll hint + CTA -->
        <div class="p-internship-scrollline" aria-hidden="true"></div>
        <div class="p-internship-cta">
          <a
            class="p-internship-entry"
            href={entryHref}
            target="_blank"
            rel="noopener noreferrer"
            data-inview="fade"
          >
            <span class="p-internship-entry__sub">冒険を始める</span>
            <span class="p-internship-entry__main">ENTRY</span>
          </a>
        </div>

        <!-- Intro -->
        <section class="p-internship-intro">
          <p class="p-internship-intro__text" data-inview>
            知るから、体感するへ。ホシザキのインターンシップでは、社員との交流や実践的なプログラムを通じて、仕事のリアルに触れることができます。あなた自身の将来を考えるきっかけを見つけてください。
          </p>
        </section>

        <!-- COURSE -->
        <section
          id="internship-course"
          class="p-internship-section p-course"
          aria-labelledby="internship-course-title"
          data-course-anchor
        >
          <InternshipHeading ja="コース" en="COURSE" />
          <div class="p-course__carousel">
            <div class="swiper p-course__swiper" data-course-swiper>
              <div class="swiper-wrapper">
                {
                  courses.map((course, index) => (
                    <CourseCard
                      id={course.id}
                      index={index}
                      title={course.title}
                      image={course.image}
                      basePath={base}
                    />
                  ))
                }
              </div>
            </div>
            <div class="p-course__nav">
              <button
                class="p-course__arrow p-course__arrow--prev"
                type="button"
                aria-label="前のコース"
                data-course-prev></button>
              <button
                class="p-course__arrow p-course__arrow--next"
                type="button"
                aria-label="次のコース"
                data-course-next></button>
            </div>
          </div>
        </section>

        <!-- Course detail (tab content per course) -->
        <div class="p-course-details" data-course-details>
          {
            courses.map((course, index) => (
              <CourseDetail course={course} index={index} basePath={base} />
            ))
          }
        </div>

        <!-- MESSAGE -->
        <section
          class="p-internship-section p-internship-message"
          aria-labelledby="internship-message-title"
        >
          <InternshipHeading ja="採用担当からのメッセージ" en="MESSAGE" />
          <p
            class="p-internship-message__body"
            data-inview
            style="--inview-i: 0"
          >
            「ホシザキを、ただの厨房機器メーカーだと思っていないか。」<br />
            私たちが求めているのは、既存の枠を超え、<br />
            新しい「食の当たり前」を創り出すパイオニア精神です。<br />
            世界中の厨房、そして医療や農業の現場を支える製品が、<br />
            どのような思考と情熱から生まれるのか。<br />
            この5日間で、あなたの「常識」を塗り替える体験が待っています。
          </p>
          <p
            class="p-internship-message__lead"
            data-inview
            style="--inview-i: 1"
          >
            さあ、その想いを翼に変えて。<br />
            エントリーはマイページから。
          </p>
          <div class="p-internship-scrollline" aria-hidden="true"></div>
          <div class="p-internship-cta">
            <a
              class="p-internship-entry"
              href={entryHref}
              target="_blank"
              rel="noopener noreferrer"
              data-inview="fade"
              style="--inview-i: 2"
            >
              <span class="p-internship-entry__sub">冒険を始める</span>
              <span class="p-internship-entry__main">ENTRY</span>
            </a>
          </div>
        </section>

        <Breadcrumb basePath={base} items={[{ label: "インターンシップ" }]} />
      </article>
    </main>

    <!-- フロート: コース詳細を読み下げた後、コース一覧へワンタップで戻す導線。
         表示の出し入れは main.js の initCourseBackToTop が .is-visible で制御。
         .p-internship は overflow:hidden のため、クリップ回避にここ（main の外）へ置く。 -->
    <button
      class="p-course-backtop"
      type="button"
      data-course-backtop
      aria-label="コース一覧へ戻る"
    >
      <span class="p-course-backtop__icon" aria-hidden="true"></span>
      <span class="p-course-backtop__label">コース一覧</span>
    </button>

    <Footer basePath={base} />
  </div>
</Layout>
