---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import InternshipHeading from "../components/InternshipHeading.astro";
import CourseCard from "../components/CourseCard.astro";
import CourseDetail from "../components/CourseDetail.astro";
import type { Course } from "../components/CourseDetail.astro";

const base = "../";

// 「冒険を始める ENTRY」は外部リンク（応募ページ）になる予定。URL は未定のため "#" を仮置き。
const entryHref = "#";

const courses: Course[] = [
  {
    id: "course-01",
    title: "【理系】開発設計職5Daysインターンシップ（機械設計コース／制御設計コース）",
    image: "course-01.png",
    points: [
      {
        num: "01",
        title: "「1台丸ごと」を生み出す開発体験",
        body: "少人数チームで開発の「1から10まで」に携わり、歯車ではないモノづくりの醍醐味を味わう。",
      },
      {
        num: "02",
        title: "最先端の開発拠点「中央研究所」が舞台",
        body: "プロが使用するCADシステムや試験室など、実際の開発環境で実務レベルの課題に没頭する。",
      },
      {
        num: "03",
        title: "第一線のプロによる個別フィードバック",
        body: "最終日の報告会では、現場で活躍する社員が学生一人ひとりに本気のフィードバックを実施。",
      },
    ],
    program: [
      {
        day: "DAY 1",
        title: "インプットと現場理解",
        body: "会社紹介、工場・試験室見学、オリエンテーション",
      },
      {
        day: "DAY 2～4",
        title: "設計開発・実務体験",
        body: "社員とのミーティング同席、実際の製品（製氷機や冷蔵庫等）の動作観察、図面作成、開発試験",
      },
      {
        day: "DAY 5",
        title: "アウトプットとフィードバック",
        body: "実習の振返り、成果報告会、現場社員（若手〜マネジメント層）からの個別フィードバック",
      },
    ],
    requirements: [
      { label: "対象", value: ["理系学生（学部・学科不問／基礎的なOffice操作ができる方）"] },
      { label: "開催時期", value: ["8月～9月の平日5日間"] },
      { label: "会場", value: ["愛知本社（中央研究所） または", "島根工場（中央研究所）"] },
      {
        label: "待遇",
        value: ["交通費実費支給", "宿泊手配あり（遠方者）", "昼食代支給（社員食堂利用可）"],
      },
      { label: "選考", value: ["マイナビよりES提出 → WEB面接（1回） → 参加決定"] },
    ],
    voices: [
      {
        avatar: "voice-01.png",
        text: "大手メーカーは分業制だと思っていましたが、ホシザキのインターンでは「1台丸ごと」設計に携われることに驚きました。チームで意見を出し合い、CADでの設計から試作まで一貫して体験できたことで、モノづくりの本質的な面白さを実感。自分のアイデアが形になる瞬間の達成感は想像以上でした。",
      },
      {
        avatar: "voice-02.png",
        text: "厨房機器という身近な製品の裏に、どれほど高度な熱力学や流体工学が使われているかを知り圧倒されました。中央研究所という最先端の設備の中で、プロが妥協なく「冷やす」技術を追求する姿を間近で見ることができ、自身の研究をどう社会実装していくかエンジニアとしての視界が一気に開けました。",
      },
      {
        avatar: "voice-03.png",
        text: "一番の収穫は、現場の最前線で活躍する社員の方々からの本気のフィードバックです。学生扱いせず、一人の技術者として厳しいながらも的確なアドバイスをいただき、自分の課題が明確になりました。座談会でも若手からベテランまで風通しが良く、ここでなら自分も大きく成長できると確信しました。",
      },
      {
        avatar: "voice-04.png",
        text: "単に機械を作るのではなく、「食のインフラを支え、環境問題を解決する」という使命感に心を打たれました。特に自然冷媒を用いた省エネ技術のワークでは、自分の学んできた知識が社会課題の解決に直結することを実感。世界シェアNo.1企業の「パイオニア・スピリット」を肌で感じた5日間でした。",
      },
    ],
  },
  {
    id: "course-02",
    title: "【理系】２Days仕事体験　工場技術コース（愛知本社）",
    image: "course-02.png",
    points: [
      {
        num: "01",
        title: "世界品質を支える生産現場のリアル",
        body: "多品種少量生産を実現するセル生産方式の現場に入り、量産設計と現場改善の最前線を体感する。",
      },
      {
        num: "02",
        title: "スマートファクトリーの実務に触れる",
        body: "ロボティクスやIoTを活用した最新の製造ラインで、生産技術エンジニアの課題解決プロセスを学ぶ。",
      },
      {
        num: "03",
        title: "現場社員との距離の近さ",
        body: "2日間を通じて若手からベテランまで多くの社員と関わり、リアルな働き方とキャリア像をつかむ。",
      },
    ],
    program: [
      {
        day: "DAY 1",
        title: "工場見学と現場理解",
        body: "会社紹介、愛知本社工場・生産ラインの見学、生産技術職オリエンテーション",
      },
      {
        day: "DAY 2",
        title: "改善ワークとフィードバック",
        body: "実際の生産ラインを題材にした改善提案ワーク、社員へのプレゼンと個別フィードバック",
      },
    ],
    requirements: [
      { label: "対象", value: ["理系学生（学部・学科不問／基礎的なOffice操作ができる方）"] },
      { label: "開催時期", value: ["8月～9月の平日2日間"] },
      { label: "会場", value: ["愛知本社（工場・生産技術部門）"] },
      {
        label: "待遇",
        value: ["交通費実費支給", "宿泊手配あり（遠方者）", "昼食代支給（社員食堂利用可）"],
      },
      { label: "選考", value: ["マイナビよりES提出 → WEB面接（1回） → 参加決定"] },
    ],
    voices: [
      {
        avatar: "voice-02.png",
        text: "生産技術は「決められたものを作るだけ」という印象を持っていましたが、量産品質とコストの両立をどう設計するかという奥深さに引き込まれました。改善ワークで自分の提案が現場の方に真剣に検討してもらえたのが嬉しかったです。",
      },
      {
        avatar: "voice-01.png",
        text: "セル生産方式の現場を初めて見て、人と設備の役割分担の巧みさに驚きました。2日間という短い期間でも、ものづくりの全体像と生産技術の面白さがしっかり伝わってきました。",
      },
      {
        avatar: "voice-04.png",
        text: "社員の方々がフラットに接してくださり、質問にも本音で答えてくれたのが印象的でした。働く環境の風通しの良さを肌で感じられた2日間でした。",
      },
      {
        avatar: "voice-03.png",
        text: "IoTやロボットを活用したスマートファクトリーの取り組みは想像以上で、自分の学んだ制御の知識が量産現場でどう活きるのかを具体的にイメージできるようになりました。",
      },
    ],
  },
  {
    id: "course-03",
    title: "【理系】１Day仕事体験　電子設計コース（WEB）",
    image: "course-03.png",
    points: [
      {
        num: "01",
        title: "製品を動かす「頭脳」を設計する",
        body: "製氷機や冷蔵庫の制御を担う電子回路・組込みソフトの開発を、第一線のエンジニアと体験する。",
      },
      {
        num: "02",
        title: "WEBで気軽に参加できる1Day",
        body: "全国どこからでも参加可能。電子設計職の仕事内容と求められる素養を短時間で理解できる。",
      },
      {
        num: "03",
        title: "現役エンジニアによる解説",
        body: "実際の開発事例をもとに、回路設計から評価までの流れを現役社員が分かりやすく解説する。",
      },
    ],
    program: [
      {
        day: "AM",
        title: "会社・職種紹介",
        body: "会社紹介、電子設計職の役割と開発事例の紹介、エンジニアによるトークセッション",
      },
      {
        day: "PM",
        title: "設計体験ワーク",
        body: "簡単な回路・制御をテーマにしたグループワーク、社員への発表と質疑応答",
      },
    ],
    requirements: [
      { label: "対象", value: ["理系学生（学部・学科不問／基礎的なOffice操作ができる方）"] },
      { label: "開催時期", value: ["7月～9月のうち1日（WEB開催）"] },
      { label: "会場", value: ["オンライン（Microsoft Teams 等）"] },
      { label: "待遇", value: ["オンライン開催のため費用負担なし"] },
      { label: "選考", value: ["マイナビよりエントリー → 参加決定"] },
    ],
    voices: [
      {
        avatar: "voice-03.png",
        text: "オンラインでも現役エンジニアの方と直接話せて、電子設計の仕事の解像度が一気に上がりました。1日でこれだけ得られるとは思っていませんでした。",
      },
      {
        avatar: "voice-04.png",
        text: "組込みソフトがどのように製品の使い心地を左右するのかを知り、ソフトとハードの境界で働く面白さに惹かれました。",
      },
      {
        avatar: "voice-01.png",
        text: "WEB開催で移動の負担がなく、地方の大学からでも気軽に参加できたのがありがたかったです。グループワークも盛り上がりました。",
      },
      {
        avatar: "voice-02.png",
        text: "回路設計から評価までの一連の流れを具体例で説明してもらえたので、自分の学びがどこで活きるのかイメージしやすくなりました。",
      },
    ],
  },
  {
    id: "course-04",
    title: "【理系】１Day仕事体験　機械設計コース（WEB）",
    image: "course-04.png",
    points: [
      {
        num: "01",
        title: "「冷やす」を形にする機械設計",
        body: "熱・流体・構造を踏まえた筐体や機構の設計プロセスを、第一線の機械設計者と体験する。",
      },
      {
        num: "02",
        title: "WEBで完結する1Dayプログラム",
        body: "全国どこからでも参加可能。機械設計職の役割と、ホシザキのものづくりの考え方を短時間で理解できる。",
      },
      {
        num: "03",
        title: "CADと設計思想を学ぶ",
        body: "実際の製品を題材に、設計者がどのような思考で形を決めているのかを具体的に学ぶ。",
      },
    ],
    program: [
      {
        day: "AM",
        title: "会社・職種紹介",
        body: "会社紹介、機械設計職の役割と開発事例の紹介、エンジニアによるトークセッション",
      },
      {
        day: "PM",
        title: "設計体験ワーク",
        body: "身近な製品をテーマにした機構・構造のグループワーク、社員への発表と質疑応答",
      },
    ],
    requirements: [
      { label: "対象", value: ["理系学生（学部・学科不問／基礎的なOffice操作ができる方）"] },
      { label: "開催時期", value: ["7月～9月のうち1日（WEB開催）"] },
      { label: "会場", value: ["オンライン（Microsoft Teams 等）"] },
      { label: "待遇", value: ["オンライン開催のため費用負担なし"] },
      { label: "選考", value: ["マイナビよりエントリー → 参加決定"] },
    ],
    voices: [
      {
        avatar: "voice-04.png",
        text: "身近な厨房機器の裏側にこれほど緻密な機械設計があるとは思いませんでした。設計者の「なぜこの形なのか」という話がとても面白かったです。",
      },
      {
        avatar: "voice-02.png",
        text: "1日で機械設計職の仕事の全体像がつかめました。熱や流体といった自分の専門が、製品開発に直結することを実感できました。",
      },
      {
        avatar: "voice-03.png",
        text: "オンラインでも設計ワークに集中して取り組め、社員の方からの的確なフィードバックで自分の考えの甘さに気づけました。",
      },
      {
        avatar: "voice-01.png",
        text: "ホシザキのものづくりの考え方に触れ、世界No.1を目指す姿勢に刺激を受けました。機械設計という仕事への憧れが強くなりました。",
      },
    ],
  },
];
---

<Layout
  basePath={base}
  title="インターンシップ｜ホシザキ本社採用サイト"
  description="ホシザキのインターンシップ情報。日本初の全自動製氷機を生み出した開発現場で、モノづくりの手触り感を体感するプログラムを紹介します。"
>
  <link
    slot="head"
    rel="stylesheet"
    href={`${base}css/swiper-bundle.min.css`}
  />
  <script slot="head" src={`${base}js/swiper-bundle.min.js`} defer is:inline></script>

  <div class="l-container">
    <Header basePath={base} logoSrc={`${base}images/internship/internship-logo.png`} />
    <main class="l-main">
      <article class="p-internship">
        <!-- Hero -->
        <section class="p-internship-hero" aria-labelledby="internship-hero-title">
          <div class="p-internship-hero__media" aria-hidden="true">
            <img src={`${base}images/internship/hero-collage-01.png`} alt="" />
            <img src={`${base}images/internship/hero-collage-02.png`} alt="" />
            <img src={`${base}images/internship/hero-collage-03.png`} alt="" />
          </div>
          <div class="p-internship-hero__overlay" aria-hidden="true"></div>
          <img
            class="p-internship-hero__ice p-internship-hero__ice--a"
            src={`${base}images/internship/ice.png`}
            alt=""
            aria-hidden="true"
          />
          <img
            class="p-internship-hero__ice p-internship-hero__ice--b"
            src={`${base}images/internship/ice.png`}
            alt=""
            aria-hidden="true"
          />
          <img
            class="p-internship-hero__penguin"
            src={`${base}images/internship/penguin-hero.png`}
            alt=""
            aria-hidden="true"
          />
          <h1 class="p-internship-hero__title" id="internship-hero-title">
            常識の先へ、一歩。<br />未知の自分に、跳びこもう。
          </h1>
        </section>

        <!-- Hero CTA -->
        <div class="p-internship-cta">
          <a class="p-internship-entry" href={entryHref}>
            <span class="p-internship-entry__sub">冒険を始める</span>
            <span class="p-internship-entry__main">ENTRY</span>
          </a>
        </div>

        <!-- Intro -->
        <section class="p-internship-intro">
          <p class="p-internship-intro__text">
            日本初の全自動製氷機を生み出したホシザキ。<br />
            私たちの開発は、一部の設計だけを担う歯車ではありません。<br />
            構想からリリースまでのすべての工程に携わるからこそ味わえる、<br />
            「モノづくりの圧倒的な手触り感」を体感してください。
          </p>
        </section>

        <!-- COURSE -->
        <section class="p-internship-section p-course" aria-labelledby="internship-course-title">
          <InternshipHeading ja="コース" en="COURSE" />
          <div class="p-course__carousel">
            <div class="swiper p-course__swiper" data-course-swiper>
              <div class="swiper-wrapper">
                {
                  courses.map((course, index) => (
                    <CourseCard
                      id={course.id}
                      index={index}
                      title={course.title}
                      image={course.image}
                      basePath={base}
                    />
                  ))
                }
              </div>
            </div>
            <div class="p-course__nav">
              <button
                class="p-course__arrow p-course__arrow--prev"
                type="button"
                aria-label="前のコース"
                data-course-prev
              ></button>
              <button
                class="p-course__arrow p-course__arrow--next"
                type="button"
                aria-label="次のコース"
                data-course-next
              ></button>
            </div>
          </div>
        </section>

        <!-- Course detail (tab content per course) -->
        <div class="p-course-details" data-course-details>
          {
            courses.map((course, index) => (
              <CourseDetail course={course} index={index} basePath={base} />
            ))
          }
        </div>

        <!-- MESSAGE -->
        <section
          class="p-internship-section p-internship-message"
          aria-labelledby="internship-message-title"
        >
          <InternshipHeading ja="採用担当からのメッセージ" en="MESSAGE" />
          <p class="p-internship-message__body">
            「ホシザキを、ただの厨房機器メーカーだと思っていないか。」<br />
            私たちが求めているのは、既存の枠を超え、<br />
            新しい「食の当たり前」を創り出すパイオニア精神です。<br />
            世界中の厨房、そして医療や農業の現場を支える製品が、<br />
            どのような思考と情熱から生まれるのか。<br />
            この5日間で、あなたの「常識」を塗り替える体験が待っています。
          </p>
          <p class="p-internship-message__lead">
            さあ、その想いを翼に変えて。<br />
            エントリーはマイページから。
          </p>
          <div class="p-internship-cta">
            <a class="p-internship-entry" href={entryHref}>
              <span class="p-internship-entry__sub">冒険を始める</span>
              <span class="p-internship-entry__main">ENTRY</span>
            </a>
          </div>
        </section>

        <Breadcrumb basePath={base} items={[{ label: "インターンシップ" }]} />
      </article>
    </main>
    <Footer basePath={base} />
  </div>
</Layout>
