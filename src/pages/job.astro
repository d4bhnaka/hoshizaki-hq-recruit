---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/PageHero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import BottomCta from "../components/BottomCta.astro";

const base = "../";

const chart = {
  create: {
    title: "製品を生み出す",
    items: ["開発・設計", "生産管理・購買", "生産技術", "品質保証"],
  },
  spread: {
    title: "製品を広める",
    items: ["国内営業企画", "海外事業企画"],
  },
  support: {
    title: "会社を管理・サポートする",
    items: ["コーポレート（総務、経理、人事、他）", "社内SE"],
  },
};

interface Job {
  title: string;
  lead: string;
  body?: string;
  image: string;
  interview?: boolean;
}

interface JobGroup {
  label: string;
  penguin: string;
  jobs: Job[];
}

const groups: JobGroup[] = [
  {
    label: "製品を生み出す",
    penguin: `${base}images/job/penguin-create.png`,
    jobs: [
      {
        title: "開発設計職",
        lead: "世界No.1を目指す新製品のゼロイチ開発（機械・電気・制御ソフト・化学）。",
        body: "設計から評価まで「1製品丸ごと」担当できる裁量の大きさと、環境対応（自然冷媒など）による社会課題の解決。",
        image: `${base}images/job/card-01.jpg`,
        interview: true,
      },
      {
        title: "生産技術職",
        lead: "開発アイデアを「高品質かつ効率的に量産」するための製造ライン構築。",
        body: "独自の多品種少量生産（セル生産方式）を支え、最新のロボティクスやIoTを駆使したスマートファクトリー化を牽引する。",
        image: `${base}images/job/card-02.jpg`,
      },
      {
        title: "品質保証職",
        lead: "世界60ヶ国で稼働する製品の安全性を担保する「最後の砦」。",
        body: "各国の厳しい安全規格・環境規制をクリアし、不具合の解析から開発へのフィードバックまで、ブランドの信頼を守り抜く。",
        image: `${base}images/job/card-03.jpg`,
      },
      {
        title: "購買・調達",
        lead: "国内外のサプライヤーから、最適な品質・コストの部品や素材を安定的に調達する。",
        body: "製造業の「利益の源泉」を担い、世界情勢を見極めながら強靭なサプライチェーンを構築する。",
        image: `${base}images/job/card-04.jpg`,
      },
    ],
  },
  {
    label: "製品を広める",
    penguin: `${base}images/job/penguin-spread.png`,
    jobs: [
      {
        title: "国内広域営業・営業企画",
        lead: "全国展開する大手飲食・小売チェーン「本部」へのソリューション提案、および全国の販売会社への販促支援。",
        body: "日本全国の市場動向を俯瞰し、億単位のダイナミックなビジネスを動かす。",
        image: `${base}images/job/card-05.jpg`,
      },
      {
        title: "海外事業企画・海外営業",
        lead: "海外M&Aの推進、海外拠点（米・欧・アジア）との経営連携、グローバル販売戦略の立案。",
        body: "異文化の市場特性を紐解き、ホシザキブランドを未開拓エリアのインフラへと育てる最前線。",
        image: `${base}images/job/card-06.jpg`,
      },
    ],
  },
  {
    label: "会社を管理・サポートする",
    penguin: `${base}images/job/penguin-support.png`,
    jobs: [
      {
        title: "コーポレート（経営企画・財務・人事・知財など）",
        lead: "グローバル成長を裏方から支える経営基盤の強化、特許戦略による技術の保護。",
        image: `${base}images/job/card-07.jpg`,
      },
      {
        title: "社内SE職（IT戦略）",
        lead: "国内外のグループを繋ぐ基幹システム統合や、製品のIoT化、社内DXの推進。",
        body: "守りの社内インフラ保守にとどまらず、攻めのITでホシザキのビジネスモデル自体を革新する。",
        image: `${base}images/job/card-08.jpg`,
      },
    ],
  },
];
---

<Layout
  basePath={base}
  title="Team HOSHIZAKI｜ホシザキ本社採用サイト"
  description="ホシザキ本社の職種紹介。開発設計、生産技術、品質保証、購買、営業、海外事業、コーポレート、社内SEなど多様なプロが集結する『Team HOSHIZAKI』をご紹介します。"
>
  <div class="l-container">
    <Header basePath={base} />
    <main class="l-main">
      <article class="p-job">
        <PageHero en="Team HOSHIZAKI" ja="ホシザキの職種紹介" variant="cloud">
          <figure class="p-job__hero-visual">
            <img
              src={`${base}images/job/page-fv.png`}
              alt=""
              width="1283"
              height="430"
              fetchpriority="high"
            />
          </figure>
        </PageHero>

        <!-- Intro copy -->
        <section class="p-job__intro" aria-label="イントロダクション">
          <p class="p-job__intro-text">
            ホシザキグループは、最前線でお客様を支える「販売会社」と、グローバル戦略の司令塔である「ホシザキ株式会社（本社）」で構成されています。本社には、次世代製品を生む開発設計、世界品質の量産を担う生産技術、IT基盤を支える社内SE、海外市場を拓く海外事業企画など多様なプロが集結。部門を超えた連携「Team
            HOSHIZAKI」で、世界No.1の食のインフラ創りに挑む本社の職種をご紹介します。
          </p>
        </section>

        <!-- Job section -->
        <section class="p-job__section" aria-labelledby="p-job-heading">
          <SectionHeading en="Job" ja="職種紹介" id="p-job-heading" align="left" />

          <!-- Org chart -->
          <div class="p-job-chart" aria-label="本社組織の役割">
            <div class="p-job-chart__top">
              <div class="p-job-chart__box p-job-chart__box--create">
                <h3 class="p-job-chart__box-title">{chart.create.title}</h3>
                <ul class="p-job-chart__box-list">
                  {chart.create.items.map((item) => <li>{item}</li>)}
                </ul>
              </div>

              <span class="p-job-chart__link p-job-chart__link--renkei" aria-hidden="true">連携</span>

              <div class="p-job-chart__box p-job-chart__box--spread">
                <h3 class="p-job-chart__box-title">{chart.spread.title}</h3>
                <ul class="p-job-chart__box-list">
                  {chart.spread.items.map((item) => <li>{item}</li>)}
                </ul>
              </div>
            </div>

            <span class="p-job-chart__link p-job-chart__link--support" aria-hidden="true">サポート</span>

            <div class="p-job-chart__box p-job-chart__box--support">
              <h3 class="p-job-chart__box-title">{chart.support.title}</h3>
              <ul class="p-job-chart__box-list">
                {chart.support.items.map((item) => <li>{item}</li>)}
              </ul>
            </div>
          </div>

          <!-- Job groups -->
          <div class="p-job__groups">
            {
              groups.map((group) => (
                <section class="p-job-group" aria-label={group.label}>
                  <div class="p-job-group__head">
                    <img
                      class="p-job-group__penguin"
                      src={group.penguin}
                      alt=""
                      loading="lazy"
                    />
                    <h3 class="p-job-group__label">{group.label}</h3>
                  </div>

                  <ul class="p-job-group__list">
                    {group.jobs.map((job) => (
                      <li class="p-job-card">
                        <div class="p-job-card__body">
                          <h4 class="p-job-card__title">{job.title}</h4>
                          <div class="p-job-card__text">
                            <p>{job.lead}</p>
                            {job.body && <p>{job.body}</p>}
                          </div>
                          {job.interview && (
                            <a class="p-job-card__interview" href={`${base}person/`}>
                              <span class="p-job-card__interview-label">この職種の先輩インタビュー</span>
                              <img
                                class="p-job-card__interview-avatar"
                                src={`${base}images/person/thumb01.png`}
                                alt=""
                                loading="lazy"
                              />
                            </a>
                          )}
                        </div>
                        <figure class="p-job-card__figure">
                          <img
                            class="p-job-card__img"
                            src={job.image}
                            alt=""
                            loading="lazy"
                            width="720"
                            height="455"
                          />
                        </figure>
                      </li>
                    ))}
                  </ul>
                </section>
              ))
            }
          </div>
        </section>

        <BottomCta basePath={base} />
        <Breadcrumb basePath={base} items={[{ label: "Team HOSHIZAKI" }]} />
      </article>
    </main>
    <Footer basePath={base} />
  </div>
</Layout>
