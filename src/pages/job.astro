---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/PageHero.astro";
import IceHeading from "../components/IceHeading.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import BottomCta from "../components/BottomCta.astro";
import { personDetails } from "../data/personDetails";
import { persons } from "../data/persons";

const base = "../";

// 先輩インタビュー導線で使う slug → イニシャル（リンクのアクセシブル名に使用。
// 社員名は非公開だがイニシャルは個別ページで公開している表記）。
const initialsBySlug = Object.fromEntries(
  personDetails.map((p) => [p.slug, p.initials]),
);
// slug → 入社年（"2014年"）。persons.ts が入社年の単一ソース。表示時に「入社」を付与。
const yearBySlug = Object.fromEntries(persons.map((p) => [p.slug, p.year]));

const chart = {
  create: {
    title: "製品を生み出す",
    items: ["開発・設計", "生産管理・購買", "生産技術", "品質保証"],
  },
  spread: {
    title: "製品を広める",
    items: ["国内販売促進", "海外事業企画"],
  },
  support: {
    title: "会社を管理・サポートする",
    items: [
      "コーポレート",
      "（総務、経理、人事、海外グループ管理、他）",
      "社内SE",
    ],
  },
};

interface Job {
  title: string;
  titleNote?: string;
  lead: string;
  body?: string;
  image: string;
  /** この職種の先輩社員の slug 一覧（/person/<slug>/ へリンク・アバターは images/person/a<slug>.png） */
  seniors?: string[];
}

interface JobGroup {
  label: string;
  penguin: string;
  jobs: Job[];
}

const groups: JobGroup[] = [
  {
    label: "製品を生み出す",
    penguin: `${base}images/job/penguin-create.png`,
    jobs: [
      {
        title: "開発設計",
        lead: "主力製品のモデルチェンジや新製品の企画・開発・設計を担当。",
        body: "少人数チームで製品丸ごと担当するため製品開発の上流工程から設計、試作、評価、量産化にいたるまでトータルに携われる環境です。",
        image: `${base}images/job/card-01.jpg`,
        seniors: ["01", "02"],
      },
      {
        title: "生産技術",
        lead: "新製品の生産ライン立ち上げ、既存ラインの補修・改善などを担当。",
        body: "円滑な量産体制を確立するため、治具の設計や生産設備の導入・保全を行います。",
        image: `${base}images/job/card-02.jpg`,
        seniors: ["03", "06"],
      },
      {
        title: "品質保証",
        lead: "製品認定や海外認証の取得、品質検査などを担当。",
        body: "お客様視点で製品と向き合い、製品開発時から出荷後まで製品の品質向上に貢献しています。",
        image: `${base}images/job/card-03.jpg`,
        seniors: ["04", "07"],
      },
      {
        title: "生産管理・購買",
        lead: "生産管理では、工場の司令塔として、生産計画の立案、資材・部品の調達などを担当。",
        body: "購買では、製品に使用される部品の購入を担当。品質・コストともに優れたものを購入するための原価低減活動も行います。",
        image: `${base}images/job/card-04.jpg`,
        seniors: ["10", "08", "09"],
      },
    ],
  },
  {
    label: "製品を広める",
    penguin: `${base}images/job/penguin-spread.png`,
    jobs: [
      {
        title: "国内販売促進",
        lead: "国内グループの販売会社の営業支援やアフターサービス活動の支援、営業施策や製品仕様の企画立案などを担当します。",
        body: "",
        image: `${base}images/job/card-05.jpg`,
        seniors: ["11"],
      },
      {
        title: "海外事業企画",
        lead: "海外事業拡大に向けた方針や構想の策定・海外グループ会社の支援、経営管理を担当します。",
        body: "",
        image: `${base}images/job/card-06.jpg`,
        seniors: ["12"],
      },
    ],
  },
  {
    label: "会社を管理・サポートする",
    penguin: `${base}images/job/penguin-support.png`,
    jobs: [
      {
        title: "コーポレート",
        titleNote: "（経理・人事・総務 他）",
        lead: "経営企画、決算書作成、人事制度設計、国内外グループの管理、社内環境の整備などを担当。ホシザキだけでなく、国内外のホシザキグループ全体に関わる業務も行います。",
        body: "",
        image: `${base}images/job/card-07.jpg`,
        seniors: ["13", "14", "15"],
      },
      {
        title: "社内SE",
        lead: "国内・海外グループに向けたITシステムの導入・運用・管理を担当。",
        body: "営業や生産を支える業務システムやITインフラの導入・運用を行う社内SEのお仕事です。",
        image: `${base}images/job/card-08.jpg`,
        seniors: ["05"],
      },
    ],
  },
];
---

<Layout
  basePath={base}
  title="Team HOSHIZAKI｜ホシザキ本社採用サイト"
  description="ホシザキ本社の職種紹介。開発設計、生産技術、品質保証、購買、営業、海外事業、コーポレート、社内SEなど、多様な職種のプロフェッショナルが部門を超えて連携する『Team HOSHIZAKI』をご紹介します。"
>
  <div class="l-container">
    <Header basePath={base} />
    <main class="l-main">
      <article class="p-job">
        <PageHero en="Team HOSHIZAKI" ja="ホシザキの職種紹介" variant="cloud">
          <figure class="p-job__hero-visual">
            <img
              src={`${base}images/job/page-fv.png`}
              alt=""
              width="1283"
              height="430"
              fetchpriority="high"
            />
          </figure>
        </PageHero>

        <!-- Intro copy -->
        <section class="p-job__intro" aria-label="イントロダクション">
          <p class="p-job__intro-text" data-inview>
            ホシザキ株式会社（本社）には、製品を生み出す開発設計や生産技術、製品を世界へ広める営業企画や海外事業企画、会社全体を支えるコーポレートや社内SEなど、多様な職種のプロフェッショナルが集まっています。それぞれが専門性を持ち寄り、部門を超えて連携する「Team
            HOSHIZAKI」として、世界No.1の食のインフラづくりに挑んでいます。ここでは、本社を構成するそれぞれの職種の役割と仕事内容をご紹介します。
          </p>
        </section>

        <!-- Job section -->
        <section class="p-job__section" aria-labelledby="p-job-heading">
          <IceHeading
            en="Job"
            ja="職種紹介"
            id="p-job-heading"
            basePath={base}
          />

          <!-- Org chart -->
          <div class="p-job-chart" aria-label="本社組織の役割">
            <div class="p-job-chart__top">
              <div
                class="p-job-chart__box p-job-chart__box--create"
                data-inview="pop"
                style="--inview-i: 0"
              >
                <h3 class="p-job-chart__box-title">{chart.create.title}</h3>
                <ul class="p-job-chart__box-list">
                  {chart.create.items.map((item) => <li>{item}</li>)}
                </ul>
              </div>

              <span
                class="p-job-chart__link p-job-chart__link--renkei"
                aria-hidden="true">連携</span
              >

              <div
                class="p-job-chart__box p-job-chart__box--spread"
                data-inview="pop"
                style="--inview-i: 1"
              >
                <h3 class="p-job-chart__box-title">{chart.spread.title}</h3>
                <ul class="p-job-chart__box-list">
                  {chart.spread.items.map((item) => <li>{item}</li>)}
                </ul>
              </div>
            </div>

            <span
              class="p-job-chart__link p-job-chart__link--support"
              aria-hidden="true">サポート</span
            >

            <div
              class="p-job-chart__box p-job-chart__box--support"
              data-inview="pop"
              style="--inview-i: 2"
            >
              <h3 class="p-job-chart__box-title">{chart.support.title}</h3>
              <ul class="p-job-chart__box-list">
                {chart.support.items.map((item) => <li>{item}</li>)}
              </ul>
            </div>
          </div>

          <!-- Job groups -->
          <div class="p-job__groups">
            {
              groups.map((group) => (
                <section class="p-job-group" aria-label={group.label}>
                  <div class="p-job-group__head">
                    <img
                      class="p-job-group__penguin"
                      src={group.penguin}
                      alt=""
                      loading="lazy"
                    />
                    <h3 class="p-job-group__label" data-inview>
                      {group.label}
                    </h3>
                  </div>

                  <ul class="p-job-group__list">
                    {group.jobs.map((job, i) => (
                      <li
                        class="p-job-card"
                        data-inview
                        style={`--inview-i: ${i}`}
                      >
                        <div class="p-job-card__body">
                          <h4 class="p-job-card__title">
                            {job.title}
                            {job.titleNote && (
                              <span class="p-job-card__title-note">
                                {job.titleNote}
                              </span>
                            )}
                          </h4>
                          <div class="p-job-card__text">
                            <p>{job.lead}</p>
                            {job.body && <p>{job.body}</p>}
                          </div>
                          {job.seniors && job.seniors.length > 0 && (
                            <div class="p-job-card__interview">
                              <span class="p-job-card__interview-label">
                                この職種の先輩インタビュー
                              </span>
                              <ul class="p-job-card__interview-list">
                                {job.seniors.map((slug) => (
                                  <li class="p-job-card__interview-item">
                                    <a
                                      class="p-job-card__interview-link"
                                      href={`${base}person/${slug}/`}
                                      aria-label={`先輩社員 ${initialsBySlug[slug]} さん（${yearBySlug[slug]}入社）のインタビューを見る`}
                                    >
                                      <img
                                        class="p-job-card__interview-avatar"
                                        src={`${base}images/person/a${slug}.png`}
                                        alt=""
                                        loading="lazy"
                                        width="58"
                                        height="58"
                                      />
                                      <span class="p-job-card__interview-meta">
                                        <span class="p-job-card__interview-initials">
                                          {initialsBySlug[slug]}
                                        </span>
                                        <span class="p-job-card__interview-year">
                                          {yearBySlug[slug]}入社
                                        </span>
                                      </span>
                                    </a>
                                  </li>
                                ))}
                              </ul>
                            </div>
                          )}
                        </div>
                        <figure class="p-job-card__figure">
                          <img
                            class="p-job-card__img"
                            src={job.image}
                            alt=""
                            loading="lazy"
                            width="720"
                            height="455"
                          />
                        </figure>
                      </li>
                    ))}
                  </ul>
                </section>
              ))
            }
          </div>
        </section>

        <BottomCta basePath={base} />
        <Breadcrumb basePath={base} items={[{ label: "Team HOSHIZAKI" }]} />
      </article>
    </main>
    <Footer basePath={base} />
  </div>
</Layout>
