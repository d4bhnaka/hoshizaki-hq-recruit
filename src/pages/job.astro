---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/PageHero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import BottomCta from "../components/BottomCta.astro";

const base = "../";

const jobs = [
  {
    title: "開発設計職",
    body: "世界No.1を目指す新製品のゼロイチ開発（機械・電気・制御ソフト・化学）。／設計から評価まで「1製品まるごと」担当できる裁量の大きさと、環境対応（自然冷媒など）による社会課題の解決。",
    image: `${base}images/job/card-01.jpg`,
  },
  {
    title: "生産技術職",
    body: "開発アイデアを「高品質かつ効率的に量産」するための製造ラインを構築。／独自の多品種少量生産（セル生産方式）を支え、最新のロボティクスやIoTを駆使したスマートファクトリー化を牽引する。",
    image: `${base}images/job/card-02.jpg`,
  },
  {
    title: "品質保証職",
    body: "世界60ヶ国で稼働する製品の安全性を担保する「最後の砦」。／各国の難しい安全規格・環境規制をクリアし、不具合の解析から開発へのフィードバックまで、ブランドの信頼を守り抜く。",
    image: `${base}images/job/card-03.jpg`,
  },
  {
    title: "購買・調達",
    body: "国内外のサプライヤーから、最適な品質・コストの部品や素材を安定的に調達する。／製造業の「利益の源泉」を担い、世界情勢を見極めながら強靭なサプライチェーンを構築する。",
    image: `${base}images/job/card-04.jpg`,
  },
  {
    title: "国内広域営業・営業企画",
    body: "全国展開する大手飲食・小売チェーン「本部」へのソリューション提案、および全国の販売会社への販促支援。／日本全国の市場動向を俯瞰し、億単位のダイナミックなビジネスを動かす。",
    image: `${base}images/job/card-05.jpg`,
  },
  {
    title: "海外事業企画・海外営業",
    body: "海外M&Aの推進、海外拠点（米・欧・アジア）との経営連携、グローバル販売戦略の立案。／異文化の市場特性を紐解き、ホシザキブランドを未開拓エリアのインフラへと育てる最前線。",
    image: `${base}images/job/card-06.jpg`,
  },
  {
    title: "コーポレート（経営企画・財務・人事・知財など）",
    body: "グローバル成長を裏方から支える経営基盤の強化、特許戦略による技術の保護。",
    image: `${base}images/job/card-07.jpg`,
  },
  {
    title: "社内SE職（IT戦略）",
    body: "国内外のグループを繋ぐ基幹システム統合や、製品のIoT化、社内DXの推進。／守りの社内インフラ保守にとどまらず、攻めのITでホシザキのビジネスモデル自体を革新する。",
    image: `${base}images/job/card-08.jpg`,
  },
];
---

<Layout
  basePath={base}
  title="Team HOSHIZAKI｜ホシザキ本社採用サイト"
  description="ホシザキ本社の職種紹介。開発設計、生産技術、品質保証、購買、営業、海外事業、コーポレート、社内SEなど多様なプロが集結する『Team HOSHIZAKI』をご紹介します。"
>
  <div class="l-container">
    <Header basePath={base} />
    <main class="l-main">
      <article class="p-job">
        <PageHero
          en="Team HOSHIZAKI"
          ja="ホシザキの職種紹介"
          variant="cloud"
          bg={`${base}images/job/page-fv.png`}
        />

        <!-- Banner -->
        <section class="p-job__banner" aria-hidden="true">
          <div class="p-job__banner-inner"></div>
        </section>

        <!-- Intro copy -->
        <section class="p-job__intro" aria-label="イントロダクション">
          <p class="p-job__intro-text">
            ホシザキグループは、最前線でお客様を支える「販売会社」と、グローバル戦略の司令塔である「ホシザキ株式会社（本社）」で構成されています。本社には、次世代製品を生み出す開発設計、世界品質の量産を担う生産技術、IT基盤を支える社内SE、海外市場を拓く海外事業企画など多様なプロが集結。部門を超えた連携「Team HOSHIZAKI」で、世界No.1の食のインフラ創りに挑む本社の職種をご紹介します。
          </p>
        </section>

        <!-- Job section -->
        <section class="p-job__section" aria-labelledby="p-job-heading">
          <SectionHeading en="Job" ja="職種紹介" id="p-job-heading" align="center" />

          <!-- Org diagram -->
          <div class="p-job-diagram" aria-label="本社組織の役割">
            <div class="p-job-diagram__box p-job-diagram__box--create">
              <h3 class="p-job-diagram__title">製品を生み出す</h3>
              <p class="p-job-diagram__sub">開発・設計／生産管理・購買／生産技術／品質保証</p>
            </div>
            <div class="p-job-diagram__box p-job-diagram__box--spread">
              <h3 class="p-job-diagram__title">製品を広める</h3>
              <p class="p-job-diagram__sub">国内営業企画／海外事業企画</p>
            </div>
            <div class="p-job-diagram__box p-job-diagram__box--support">
              <h3 class="p-job-diagram__title">会社を管理・サポートする</h3>
              <p class="p-job-diagram__sub">コーポレート（総務、経理、人事、他）／社内SE</p>
            </div>

            <span class="p-job-diagram__arrow p-job-diagram__arrow--top" aria-hidden="true">
              <span class="p-job-diagram__arrow-label">連携</span>
            </span>
            <span class="p-job-diagram__arrow p-job-diagram__arrow--left" aria-hidden="true">
              <span class="p-job-diagram__arrow-label">サポート</span>
            </span>
            <span class="p-job-diagram__arrow p-job-diagram__arrow--right" aria-hidden="true">
              <span class="p-job-diagram__arrow-label">サポート</span>
            </span>
          </div>

          <!-- Job cards list -->
          <ul class="p-job__list">
            {
              jobs.map((job, index) => (
                <li class={`p-job__item${index % 2 === 1 ? " p-job__item--reverse" : ""}`}>
                  <div class="p-job__item-body">
                    <h3 class="p-job__item-title">{job.title}</h3>
                    <p class="p-job__item-text">{job.body}</p>
                  </div>
                  <figure class="p-job__item-figure">
                    <img
                      class="p-job__item-img"
                      src={job.image}
                      alt=""
                      loading="lazy"
                      onerror="this.style.visibility='hidden'"
                    />
                  </figure>
                </li>
              ))
            }
          </ul>

          <!-- Decorative penguins -->
          <div class="p-job__penguins" aria-hidden="true">
            <img class="p-job__penguin p-job__penguin--01" src={`${base}images/top/ap_01.png`} alt="" />
            <img class="p-job__penguin p-job__penguin--02" src={`${base}images/top/ap_03.png`} alt="" />
            <img class="p-job__penguin p-job__penguin--03" src={`${base}images/top/ap_05.png`} alt="" />
          </div>
        </section>

        <BottomCta basePath={base} />
        <Breadcrumb basePath={base} items={[{ label: "Team HOSHIZAKI" }]} />
      </article>
    </main>
    <Footer basePath={base} />
  </div>
</Layout>
