---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import BottomCta from "../components/BottomCta.astro";
import { specialStories } from "../data/specialStories";

const basePath = "./";

// Hero — 本文導入コピー（Figma 296:7298 のテキストノード）
const heroBodyLines = [
  "ホシザキを、",
  "厨房機器だけのメーカーと思っていないか。",
  "国内のフードサービス機器でトップクラスのシェア。",
  "でも、それだけではない。",
  "世界60カ国以上に広がるネットワーク、",
  "海外売上比率50％にも迫るグローバル企業。",
  "食材ロス削減、環境負荷軽減、",
  "そして医療や食品加工といった新分野への挑戦。",
  "常識や思い込みに縛られるな。",
  "これからも、ホシザキは進化を止めない。",
];

// 3 つのコーポレートナビ (KNOW HOSHIZAKI band)。Figma の y=3283-5502 帯に
// 階段状に配置される。`pos` は `_p-top.scss` 側で扱う配置クラス。
const trioCards = [
  {
    pos: "whats",
    href: `${basePath}fact/`,
    en1: "What's",
    en2: "HOSHIZAKI",
    label: "キーワードで見る",
    img: `${basePath}images/top/sec01_img.png`,
    imgAlt: "飛ぶペンギン",
    button: `${basePath}images/top/link-button-ice_02.png`,
  },
  {
    pos: "beyond",
    href: `${basePath}strategy/`,
    en1: "Beyond",
    en2: "HOSHIZAKI",
    label: "ホシザキの海外展開",
    img: `${basePath}images/top/sec02_img.png`,
    imgAlt: "地球儀の中で泳ぐペンギン",
    button: `${basePath}images/top/link-button-ice_03.png`,
  },
  {
    pos: "team",
    href: `${basePath}job/`,
    en1: "Team",
    en2: "HOSHIZAKI",
    label: "グループの役割",
    img: `${basePath}images/top/sec03_img.png`,
    imgAlt: "並ぶ3羽のペンギン",
    button: `${basePath}images/top/link-button-ice_04.png`,
  },
];

const specialCards = specialStories.map((story, i) => ({
  href: `${basePath}special/${story.slug}/`,
  num: story.num,
  category: story.category,
  titleLines: story.titleLines,
  sub: story.sub,
  bg: `${basePath}images/special/${String(i + 1).padStart(2, "0")}.png`,
  avatars: Array.from({ length: story.avatars }).map((_, a) => ({
    src: `${basePath}images/special/sp${String(i + 1).padStart(2, "0")}_pic${String(a + 1).padStart(2, "0")}.png`,
    alt: `${story.category} 出演者 ${a + 1}`,
  })),
}));
---

<Layout basePath={basePath} title="ホシザキ本社採用サイト | 常識の先へ、跳べ。">
  <Header basePath={basePath} />

  <main class="p-top">
    {/* ============================================ */}
    {/* S1. Hero (Figma y: 0–1674) */}
    {/* ============================================ */}
    <section class="p-top-hero" aria-label="メインビジュアル">
      <div class="p-top-hero__sky">
        {/* 装飾の雲 */}
        <img
          class="p-top-hero__cloud p-top-hero__cloud--1"
          src={`${basePath}images/top/cloud01.png`}
          alt=""
          aria-hidden="true"
        />
        <img
          class="p-top-hero__cloud p-top-hero__cloud--2"
          src={`${basePath}images/top/cloud02.png`}
          alt=""
          aria-hidden="true"
        />
        <img
          class="p-top-hero__cloud p-top-hero__cloud--3"
          src={`${basePath}images/top/cloud03.png`}
          alt=""
          aria-hidden="true"
        />

        {/* 飛ぶペンギン (5 羽) */}
        <img
          class="p-top-hero__penguin p-top-hero__penguin--1"
          src={`${basePath}images/top/ap_01.png`}
          alt=""
          aria-hidden="true"
        />
        <img
          class="p-top-hero__penguin p-top-hero__penguin--2"
          src={`${basePath}images/top/ap_02.png`}
          alt=""
          aria-hidden="true"
        />
        <img
          class="p-top-hero__penguin p-top-hero__penguin--3"
          src={`${basePath}images/top/ap_03.png`}
          alt=""
          aria-hidden="true"
        />
        <img
          class="p-top-hero__penguin p-top-hero__penguin--4"
          src={`${basePath}images/top/ap_04.png`}
          alt=""
          aria-hidden="true"
        />
        <img
          class="p-top-hero__penguin p-top-hero__penguin--5"
          src={`${basePath}images/top/ap_05.png`}
          alt=""
          aria-hidden="true"
        />

        <div class="p-top-hero__inner">
          <h1 class="p-top-hero__catch">
            <span class="p-top-hero__catch-line">常識の</span>
            <span class="p-top-hero__catch-line">先へ、</span>
            <span class="p-top-hero__catch-line">跳べ。</span>
          </h1>

          <aside class="p-top-hero__movie" aria-label="CONCEPT MOVIE">
            <p class="p-top-hero__movie-en">CONCEPT MOVIE</p>
            <button
              type="button"
              class="p-top-hero__movie-thumb"
              aria-label="コンセプトムービーを再生"
            >
              <span class="p-top-hero__movie-play" aria-hidden="true">
                <span class="p-top-hero__movie-triangle"></span>
              </span>
            </button>
          </aside>

          <div class="p-top-hero__body">
            <ol class="p-top-hero__body-list">
              {
                heroBodyLines.map((line) => (
                  <li class="p-top-hero__body-line">{line}</li>
                ))
              }
            </ol>
            <p class="p-top-hero__body-outro">さあ、その想いを翼に変えて。</p>
          </div>
        </div>

        {/* 都市のシルエット (下部) */}
        <img
          class="p-top-hero__city"
          src={`${basePath}images/top/bg-city.png`}
          alt=""
          aria-hidden="true"
        />
      </div>
    </section>

    {/* ============================================ */}
    {/* S2. PIONEER SPIRIT (Figma y: 2562–3291 / Group 296:7176) */}
    {/* ============================================ */}
    <section class="p-top-pioneer" aria-label="採用メッセージ">
      <div class="p-top-pioneer__inner">
        <header class="p-top-pioneer__heading">
          <h2 class="p-top-pioneer__en">PIONEER SPIRIT</h2>
          <p class="p-top-pioneer__ja">採用メッセージ</p>
        </header>

        <a
          class="p-top-pioneer__button c-ice-link"
          href={`${basePath}message/`}
          aria-label="採用メッセージを読む"
        >
          <img
            class="c-ice-link__bg"
            src={`${basePath}images/top/link-button-ice_01.png`}
            alt=""
            aria-hidden="true"
          />
          <span class="c-ice-link__inner">
            <span class="c-ice-link__label">採用メッセージ</span>
            <span class="c-ice-link__more">READ MORE</span>
          </span>
        </a>

        <div class="p-top-pioneer__visual" aria-hidden="true">
          <img
            class="p-top-pioneer__penguins"
            src={`${basePath}images/top/pioneer.png`}
            alt=""
          />
        </div>
      </div>
    </section>

    {/* ============================================ */}
    {/* S3. KNOW HOSHIZAKI / Trio (Figma y: 3283–5502 / 365:13388 帯) */}
    {/* ============================================ */}
    <section class="p-top-trio" aria-label="ホシザキを知る3つの視点">
      <div class="p-top-trio__inner">
        {/* 装飾の氷キューブ */}
        <img
          class="p-top-trio__cube p-top-trio__cube--1"
          src={`${basePath}images/top/ice_cubes_01.png`}
          alt=""
          aria-hidden="true"
        />
        <img
          class="p-top-trio__cube p-top-trio__cube--2"
          src={`${basePath}images/top/ice_cubes_02.png`}
          alt=""
          aria-hidden="true"
        />
        <img
          class="p-top-trio__cube p-top-trio__cube--3"
          src={`${basePath}images/top/ice_cubes_03.png`}
          alt=""
          aria-hidden="true"
        />
        <img
          class="p-top-trio__cube p-top-trio__cube--4"
          src={`${basePath}images/top/ice_cubes_04.png`}
          alt=""
          aria-hidden="true"
        />

        {
          trioCards.map((card) => (
            <a
              class={`p-top-trio__card p-top-trio__card--${card.pos}`}
              href={card.href}
            >
              <img
                class="p-top-trio__card-img"
                src={card.img}
                alt={card.imgAlt}
              />
              <span class="p-top-trio__card-text">
                <span class="p-top-trio__card-en1">{card.en1}</span>
                <span class="p-top-trio__card-en2">{card.en2}</span>
              </span>
              <span class="p-top-trio__card-button c-ice-link">
                <img
                  class="c-ice-link__bg"
                  src={card.button}
                  alt=""
                  aria-hidden="true"
                />
                <span class="c-ice-link__inner">
                  <span class="c-ice-link__label">{card.label}</span>
                  <span class="c-ice-link__more">READ MORE</span>
                </span>
              </span>
            </a>
          ))
        }
      </div>
    </section>

    {/* ============================================ */}
    {
      /* S4. 先輩たちの「ここに決めた！」 (Figma y: 4783–5269 / Group 367:857) */
    }
    {/* ============================================ */}
    <section class="p-top-decided" aria-label="先輩たちの「ここに決めた！」">
      <div class="p-top-decided__inner">
        <img
          class="p-top-decided__photo"
          src={`${basePath}images/top/sec04_img.png`}
          alt="星型の氷フレームに収まった3名の先輩"
        />
        <h2 class="p-top-decided__title">
          <span class="p-top-decided__title-line1">先輩たちの</span>
          <span class="p-top-decided__title-line2"
            >「<span class="p-top-decided__title-emph">ここに決めた</span><span
              class="p-top-decided__title-bang">！</span
            >」</span
          >
        </h2>
        <a
          class="p-top-decided__button c-ice-link"
          href={`${basePath}person/`}
          aria-label="はたらく人を知る"
        >
          <img
            class="c-ice-link__bg"
            src={`${basePath}images/top/link-button-ice_05.png`}
            alt=""
            aria-hidden="true"
          />
          <span class="c-ice-link__inner">
            <span class="c-ice-link__label">はたらく人を知る</span>
            <span class="c-ice-link__more">READ MORE</span>
          </span>
        </a>
      </div>
    </section>

    {/* ============================================ */}
    {/* S5. はたらく環境を知る (Figma y: 5502–6162 / Group 296:7285) */}
    {/* ============================================ */}
    <section class="p-top-env" aria-label="はたらく環境を知る">
      <img
        class="p-top-env__photo"
        src={`${basePath}images/top/section-bg-environment.jpg`}
        alt=""
        aria-hidden="true"
      />
      <div class="p-top-env__inner">
        <header class="p-top-env__heading">
          <h2 class="p-top-env__title">はたらく環境を知る</h2>
          <p class="p-top-env__sub">制度も環境も、妥協せずに整えてきました。</p>
        </header>
        <a
          class="p-top-env__button c-ice-link"
          href={`${basePath}environment/`}
          aria-label="はたらく環境を知る"
        >
          <img
            class="c-ice-link__bg"
            src={`${basePath}images/top/link-button-ice_06.png`}
            alt=""
            aria-hidden="true"
          />
          <span class="c-ice-link__inner">
            <span class="c-ice-link__label">はたらく環境を知る</span>
            <span class="c-ice-link__more">READ MORE</span>
          </span>
        </a>
      </div>
    </section>

    {/* ============================================ */}
    {/* S6. SPECIAL CONTENTS (Figma y: 6162–8450) */}
    {/* ============================================ */}
    <section class="p-top-special" aria-label="SPECIAL CONTENTS">
      <header class="p-top-special__heading">
        <h2 class="p-top-special__en">
          <span>SPECIAL</span>
          <span>CONTENTS</span>
        </h2>
        <p class="p-top-special__ja">ホシザキではたらくリアル</p>
      </header>

      <ul class="p-top-special__list">
        {
          specialCards.map((card) => (
            <li class="p-top-special__item">
              <a class="p-top-special__card" href={card.href}>
                <div class="p-top-special__card-body">
                  <p class="p-top-special__card-cat">{card.category}</p>
                  <p class="p-top-special__card-title">
                    <span>{card.titleLines[0]}</span>
                    <span>{card.titleLines[1]}</span>
                  </p>
                  <p class="p-top-special__card-sub">{card.sub}</p>
                  <ul class="p-top-special__card-avatars" aria-hidden="true">
                    {card.avatars.map((a) => (
                      <li class="p-top-special__card-avatar">
                        <img src={a.src} alt="" loading="lazy" />
                      </li>
                    ))}
                  </ul>
                </div>
                <div class="p-top-special__card-photo" aria-hidden="true">
                  <img src={card.bg} alt="" loading="lazy" />
                </div>
                <span class="p-top-special__card-more" aria-hidden="true">
                  <span class="p-top-special__card-more-text">READ MORE</span>
                  <span class="p-top-special__card-more-arrow" />
                </span>
              </a>
            </li>
          ))
        }
      </ul>
    </section>

    <BottomCta basePath={basePath} />
  </main>

  <Footer basePath={basePath} />
</Layout>
