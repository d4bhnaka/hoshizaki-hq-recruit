---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import BottomCta from "../components/BottomCta.astro";
import SpecialContents from "../components/SpecialContents.astro";

const basePath = "./";

// Hero — 本文導入コピー（Figma 296:7298 のテキストノード）
const heroBodyLines = [
  "ホシザキを、",
  "厨房機器だけのメーカーと思っていないか。",
  "国内のフードサービス機器でトップクラスのシェア。",
  "でも、それだけではない。",
  "世界60カ国以上に広がるネットワーク、",
  "海外売上比率50％にも迫るグローバル企業。",
  "食材ロス削減、環境負荷軽減、",
  "そして医療や食品加工といった新分野への挑戦。",
  "常識や思い込みに縛られるな。",
  "これからも、ホシザキは進化を止めない。",
];

// 飛ぶペンギン（Figma `penguins` フレーム 296:12720 の各 ap_0x）
const heroPenguins = [
  { n: 3, img: "ap_03.png" },
  { n: 4, img: "ap_04.png" },
  { n: 1, img: "ap_01.png" },
  { n: 2, img: "ap_02.png" },
  { n: 5, img: "ap_05.png" },
];

// S3 コーポレートナビ 3 枚（What's / Beyond / Team）。Figma 365:13388 帯に絶対配置。
const trioCards = [
  {
    pos: "whats",
    href: `${basePath}fact/`,
    en: ["What's", "HOSHIZAKI"],
    label: "キーワードで見る",
    img: `${basePath}images/top/sec01_img.png`,
    imgAlt: "飛ぶペンギン",
  },
  {
    pos: "beyond",
    href: `${basePath}strategy/`,
    en: ["Beyond", "HOSHIZAKI"],
    label: "ホシザキの海外展開",
    img: `${basePath}images/top/sec02_img.png`,
    imgAlt: "地球儀の中を泳ぐペンギン",
  },
  {
    pos: "team",
    href: `${basePath}job/`,
    en: ["Team", "HOSHIZAKI"],
    label: "グループの役割",
    img: `${basePath}images/top/sec03_img.png`,
    imgAlt: "寄り添う3羽のペンギン",
  },
];
---

<Layout basePath={basePath} title="ホシザキ本社採用サイト | 常識の先へ、跳べ。">
  <Header basePath={basePath} />

  <main class="p-top">
    {/* ============================================ */}
    {/* S1. Hero (Figma y: 0–2562) */}
    {/* ============================================ */}
    <section class="p-top-hero" aria-label="メインビジュアル">
      <div class="p-top-hero__stage">
        {/* タグライン「常識の／先へ、／跳べ。」 */}
        <h1 class="p-top-hero__catch">
          <span class="p-top-hero__catch-line">常識の</span>
          <span class="p-top-hero__catch-line">先へ、</span>
          <span class="p-top-hero__catch-line">跳べ。</span>
        </h1>

        {/* 飛ぶペンギン 5 羽 */}
        {
          heroPenguins.map((p) => (
            <img
              class={`p-top-hero__penguin p-top-hero__penguin--${p.n}`}
              src={`${basePath}images/top/${p.img}`}
              alt=""
              aria-hidden="true"
            />
          ))
        }

        {/* 本文導入コピー */}
        <ol class="p-top-hero__body">
          {
            heroBodyLines.map((line) => (
              <li class="p-top-hero__body-line">{line}</li>
            ))
          }
        </ol>

        {/* CONCEPT MOVIE */}
        <p class="p-top-hero__movie-label">CONCEPT MOVIE</p>
        <button
          type="button"
          class="p-top-hero__movie"
          aria-label="コンセプトムービーを再生"
          data-movie-open
          aria-haspopup="dialog"
          aria-controls="concept-movie-modal"
        >
          <img
            class="p-top-hero__movie-poster"
            src={`${basePath}images/top/concept-movie-poster.png`}
            alt=""
          />
          <span class="p-top-hero__movie-overlay"
            >さぁ、その想いを翼に変えて。</span
          >
          <span class="p-top-hero__movie-play" aria-hidden="true">
            <span class="p-top-hero__movie-triangle"></span>
          </span>
        </button>

        {/* 「さぁ、その想いを翼に変えて。」(都市の上) */}
        <p class="p-top-hero__outro">さぁ、その想いを翼に変えて。</p>

        {/* 都市イラスト（下端・背景） */}
        <img
          class="p-top-hero__city"
          src={`${basePath}images/top/bg-city.png`}
          alt=""
          aria-hidden="true"
        />
      </div>
    </section>

    {/* ============================================ */}
    {/* S2. PIONEER SPIRIT (Figma y: 2562–3291 / Group 296:7176) */}
    {/* ============================================ */}
    <section class="p-top-pioneer" aria-label="採用メッセージ">
      <div class="p-top-pioneer__stage">
        <h2 class="p-top-pioneer__en" data-inview style="--inview-i: 0">
          PIONEER SPIRIT
        </h2>
        <p class="p-top-pioneer__ja" data-inview style="--inview-i: 1">
          採用メッセージ
        </p>
        <a
          class="p-top-pioneer__button c-ice-link c-ice-link--fluid"
          href={`${basePath}message/`}
          aria-label="採用メッセージを読む"
          data-inview="fade"
          style="--inview-i: 2"
        >
          <img
            class="c-ice-link__bg"
            src={`${basePath}images/common/link-button-ice.png`}
            alt=""
            aria-hidden="true"
          />
          <span class="c-ice-link__inner">
            <span class="c-ice-link__label">採用メッセージ</span>
            <span class="c-ice-link__more">READ MORE</span>
          </span>
        </a>
        <img
          class="p-top-pioneer__visual"
          src={`${basePath}images/top/pioneer.png`}
          alt=""
          aria-hidden="true"
        />
      </div>
    </section>

    {/* ============================================ */}
    {/* S3+S4. KNOW HOSHIZAKI / ここに決めた! (Figma y: 3283–5502 / 365:13388 帯) */}
    {/* ============================================ */}
    <section
      class="p-top-trio"
      aria-label="ホシザキを知る視点とはたらく人を知る導線"
    >
      <div class="p-top-trio__stage">
        {/* 装飾の氷キューブ */}
        {
          [1, 2, 3, 4].map((i) => (
            <img
              class={`p-top-trio__cube p-top-trio__cube--${i}`}
              src={`${basePath}images/top/ice_cubes_0${i}.png`}
              alt=""
              aria-hidden="true"
            />
          ))
        }

        {/* What's / Beyond / Team */}
        {
          trioCards.map((card) => (
            <Fragment>
              <img
                class={`p-top-trio__img p-top-trio__img--${card.pos}`}
                src={card.img}
                alt={card.imgAlt}
                data-inview
                style="--inview-i: 0"
              />
              <p
                class={`p-top-trio__en p-top-trio__en--${card.pos}`}
                data-inview
                style="--inview-i: 1"
              >
                <span class="p-top-trio__en-line">{card.en[0]}</span>
                <span class="p-top-trio__en-line">{card.en[1]}</span>
              </p>
              <a
                class={`p-top-trio__button p-top-trio__button--${card.pos} c-ice-link c-ice-link--fluid`}
                href={card.href}
                data-inview="fade"
                style="--inview-i: 2"
              >
                <img
                  class="c-ice-link__bg"
                  src={`${basePath}images/common/link-button-ice.png`}
                  alt=""
                  aria-hidden="true"
                />
                <span class="c-ice-link__inner">
                  <span class="c-ice-link__label">{card.label}</span>
                  <span class="c-ice-link__more">READ MORE</span>
                </span>
              </a>
            </Fragment>
          ))
        }

        {/* 先輩たちの「ここに決めた！」 */}
        <img
          class="p-top-trio__img p-top-trio__img--decided"
          src={`${basePath}images/top/sec04_img.png`}
          alt="星型の氷フレームに収まった先輩社員たち"
          data-inview
          style="--inview-i: 0"
        />
        <p class="p-top-trio__decided-lead" data-inview style="--inview-i: 1">
          先輩たちの
        </p>
        <img
          class="p-top-trio__decided-koko"
          src={`${basePath}images/top/koko-decided.svg`}
          alt="「ここに決めた！」"
          data-inview
          style="--inview-i: 2"
        />
        <a
          class="p-top-trio__button p-top-trio__button--decided c-ice-link c-ice-link--fluid"
          href={`${basePath}person/`}
          aria-label="はたらく人を知る"
          data-inview="fade"
          style="--inview-i: 3"
        >
          <img
            class="c-ice-link__bg"
            src={`${basePath}images/common/link-button-ice.png`}
            alt=""
            aria-hidden="true"
          />
          <span class="c-ice-link__inner">
            <span class="c-ice-link__label">はたらく人を知る</span>
            <span class="c-ice-link__more">READ MORE</span>
          </span>
        </a>
      </div>
    </section>

    {/* ============================================ */}
    {/* S5. はたらく環境を知る (Figma y: 5502–6162 / Group 296:7285) */}
    {/* ============================================ */}
    <section class="p-top-env" aria-label="はたらく環境を知る">
      <img
        class="p-top-env__photo"
        src={`${basePath}images/top/section-bg-environment.jpg`}
        alt=""
        aria-hidden="true"
      />
      <div class="p-top-env__inner">
        <header class="p-top-env__heading">
          <h2 class="p-top-env__title" data-inview style="--inview-i: 0">
            はたらく環境を知る
          </h2>
          <p class="p-top-env__sub" data-inview style="--inview-i: 1">
            制度も環境も、妥協せずに整えてきました。
          </p>
        </header>
        <a
          class="p-top-env__button c-ice-link"
          href={`${basePath}environment/`}
          aria-label="はたらく環境を知る"
          data-inview="fade"
          style="--inview-i: 2"
        >
          <img
            class="c-ice-link__bg"
            src={`${basePath}images/common/link-button-ice.png`}
            alt=""
            aria-hidden="true"
          />
          <span class="c-ice-link__inner">
            <span class="c-ice-link__label">はたらく環境を知る</span>
            <span class="c-ice-link__more">READ MORE</span>
          </span>
        </a>
      </div>
    </section>

    {/* ============================================ */}
    {/* S6. SPECIAL CONTENTS (Figma y: 6162–8450) */}
    {/* 見出し・カード・スクロール連動スタック演出は特集ページ（/special/）と */}
    {/* 共通の SpecialContents コンポーネントを使用する。 */}
    {/* ============================================ */}
    <div class="p-special">
      <SpecialContents
        basePath={basePath}
        storyBase={`${basePath}special/`}
        headingTag="h2"
      />
    </div>

    <BottomCta basePath={basePath} />

    {/* ============================================ */}
    {/* コンセプトムービー モーダル */}
    {/* 初期は hidden。ボタン押下で開き、video を先頭から再生。 */}
    {/* 動画(約25MB)を初期ロードしないよう preload="none"。 */}
    {/* ============================================ */}
    <div
      class="c-movie-modal"
      id="concept-movie-modal"
      data-movie-modal
      role="dialog"
      aria-modal="true"
      aria-label="コンセプトムービー"
      hidden
    >
      <div class="c-movie-modal__backdrop" data-movie-close></div>
      <div class="c-movie-modal__dialog">
        <button
          type="button"
          class="c-movie-modal__close"
          data-movie-close
          aria-label="ムービーを閉じる"
        >
          <span class="c-movie-modal__close-icon" aria-hidden="true"></span>
        </button>
        <div class="c-movie-modal__frame">
          <video
            class="c-movie-modal__video"
            data-movie-video
            controls
            playsinline
            preload="none"
            poster={`${basePath}images/top/concept-movie-poster.png`}
          >
            <source src={`${basePath}videos/hoshizaki_01.mp4`} type="video/mp4" />
            お使いのブラウザは動画の再生に対応していません。
          </video>
        </div>
      </div>
    </div>
  </main>

  <Footer basePath={basePath} />
</Layout>
