---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import BottomCta from "../components/BottomCta.astro";
import IceLinkButton from "../components/IceLinkButton.astro";
import SpecialContents from "../components/SpecialContents.astro";

const basePath = "./";

// Hero — 本文導入コピー（Figma 296:7298 のテキストノード）
const heroBodyLines = [
  "ホシザキを、",
  "厨房機器だけのメーカーと思っていないか。",
  "国内のフードサービス機器でトップクラスのシェア。",
  "でも、それだけではない。",
  "世界60カ国以上に広がるネットワーク、",
  "海外売上比率50％にも迫るグローバル企業。",
  "食材ロス削減、環境負荷軽減、",
  "そして医療や食品加工といった新分野への挑戦。",
  "常識や思い込みに縛られるな。",
  "これからも、ホシザキは進化を止めない。",
];

// 飛ぶペンギン（Figma `penguins` フレーム 296:12720 の各 ap_0x）
const heroPenguins = [
  { n: 3, img: "ap_03.png" },
  { n: 4, img: "ap_04.png" },
  { n: 1, img: "ap_01.png" },
  { n: 2, img: "ap_02.png" },
  { n: 5, img: "ap_05.png" },
];

// S3 装飾氷キューブの視差速度（data-parallax / main.js initParallax が参照）。
// 正＝スクロールより遅く流れる（奥に見える）、負＝速く流れる（手前に見える）。
// 大きいキューブほど手前・小さいほど奥になるよう係数を散らして奥行きを出す。
const trioCubeSpeeds = [-0.18, 0.14, 0.1, -0.24];

// S3 コーポレートナビ 3 枚（What's / Beyond / Team）。Figma 365:13388 帯に絶対配置。
const trioCards = [
  {
    pos: "whats",
    href: `${basePath}fact/`,
    en: ["What's", "HOSHIZAKI"],
    label: "キーワードで見る",
    img: `${basePath}images/top/sec01_img.png`,
    imgAlt: "飛ぶペンギン",
  },
  {
    pos: "beyond",
    href: `${basePath}strategy/`,
    en: ["Beyond", "HOSHIZAKI"],
    label: "ホシザキの海外展開",
    img: `${basePath}images/top/sec02_img.png`,
    imgAlt: "地球儀の中を泳ぐペンギン",
  },
  {
    pos: "team",
    href: `${basePath}job/`,
    en: ["Team", "HOSHIZAKI"],
    label: "グループの役割",
    img: `${basePath}images/top/sec03_img.png`,
    imgAlt: "寄り添う3羽のペンギン",
  },
];
---

<Layout basePath={basePath} title="ホシザキ本社採用サイト | 常識の先へ、跳べ。">
  <Header basePath={basePath} />

  <main class="p-top">
    {/* ============================================ */}
    {/* S1. Hero (Figma y: 0–2562) */}
    {/* ============================================ */}
    <section class="p-top-hero" aria-label="メインビジュアル">
      <div class="p-top-hero__stage">
        {/* タグライン「常識の／先へ、／跳べ。」 */}
        {/* ローディング演出: 行ごとに白い長方形が左→右に伸びて覆い、 */}
        {/* 続けて左→右へ退きながら文字を現す（純CSS / _p-top.scss）。 */}
        {/* --catch-i は行ごとのディレイ順（0,1,2）。 */}
        <h1 class="p-top-hero__catch">
          <span class="p-top-hero__catch-line" style="--catch-i: 0">
            <span class="p-top-hero__catch-word">常識の</span>
          </span>
          <span class="p-top-hero__catch-line" style="--catch-i: 1">
            <span class="p-top-hero__catch-word">先へ、</span>
          </span>
          <span class="p-top-hero__catch-line" style="--catch-i: 2">
            <span class="p-top-hero__catch-word">跳べ。</span>
          </span>
        </h1>

        {/* 飛ぶペンギン 5 羽 */}
        {
          heroPenguins.map((p) => (
            <img
              class={`p-top-hero__penguin p-top-hero__penguin--${p.n}`}
              src={`${basePath}images/top/${p.img}`}
              alt=""
              aria-hidden="true"
            />
          ))
        }

        {/* 本文導入コピー */}
        {/* KV(キャッチコピー)と同じ「白バーで塗ってから抜いて現す」演出を */}
        {/* 行ごとに適用。--body-i は行ごとのディレイ順（0,1,2,…）。 */}
        <ol class="p-top-hero__body">
          {
            heroBodyLines.map((line, i) => (
              <li class="p-top-hero__body-line" style={`--body-i: ${i}`}>
                <span class="p-top-hero__body-text">{line}</span>
              </li>
            ))
          }
        </ol>

        {/* CONCEPT MOVIE */}
        {/* ヒーローステージ上の絶対配置のため、座標を動かさない "fade"（不透明度のみ）で
            ゆっくりフェードイン（M3-A1）。 */}
        <p class="p-top-hero__movie-label" data-inview="fade" style="--inview-i: 0">CONCEPT MOVIE</p>
        <button
          type="button"
          class="p-top-hero__movie"
          aria-label="コンセプトムービーを再生"
          data-movie-open
          aria-haspopup="dialog"
          aria-controls="concept-movie-modal"
          data-inview="fade"
          style="--inview-i: 1"
        >
          <img
            class="p-top-hero__movie-poster"
            src={`${basePath}images/top/concept-movie-poster.png`}
            alt=""
          />
          <span class="p-top-hero__movie-overlay"
            >さぁ、その想いを翼に変えて。</span
          >
          <span class="p-top-hero__movie-play" aria-hidden="true">
            <span class="p-top-hero__movie-triangle"></span>
          </span>
        </button>

        {/* 「さぁ、その想いを翼に変えて。」(都市の上) */}
        {/* 本文導入コピーと同じ「白バーで塗ってから抜いて現す」演出。 */}
        <p class="p-top-hero__outro">
          <span class="p-top-hero__outro-text">さぁ、その想いを翼に変えて。</span>
        </p>

        {/* 都市イラスト（下端・背景） */}
        <img
          class="p-top-hero__city"
          src={`${basePath}images/top/bg-city.png`}
          alt=""
          aria-hidden="true"
        />

        {/* 雲（Figma 296:10806 / 296:9053 / 296:7300） */}
        {/* 透過PNGをスクリーン合成・不透明度80%で空に重ねる（_p-top.scss） */}
        <img
          class="p-top-hero__cloud p-top-hero__cloud--left"
          src={`${basePath}images/top/cloud02.png`}
          alt=""
          aria-hidden="true"
        />
        <img
          class="p-top-hero__cloud p-top-hero__cloud--center"
          src={`${basePath}images/top/cloud01.png`}
          alt=""
          aria-hidden="true"
        />
        <img
          class="p-top-hero__cloud p-top-hero__cloud--right"
          src={`${basePath}images/top/cloud03.png`}
          alt=""
          aria-hidden="true"
        />

        {/* SP 用の雲 2 つ（Figma top_sp 431:2945 / 431:1191 = Group 2184。PC では非表示） */}
        <img
          class="p-top-hero__cloud p-top-hero__cloud--sp-l"
          src={`${basePath}images/common/hero-cloud.png`}
          alt=""
          aria-hidden="true"
        />
        <img
          class="p-top-hero__cloud p-top-hero__cloud--sp-r"
          src={`${basePath}images/common/hero-cloud.png`}
          alt=""
          aria-hidden="true"
        />
      </div>
    </section>

    {/* ============================================ */}
    {/* S2. PIONEER SPIRIT (Figma y: 2562–3291 / Group 296:7176) */}
    {/* ============================================ */}
    <section class="p-top-pioneer" aria-label="採用メッセージ">
      <div class="p-top-pioneer__stage">
        <h2 class="p-top-pioneer__en" data-inview style="--inview-i: 0">
          PIONEER SPIRIT
        </h2>
        <p class="p-top-pioneer__ja" data-inview style="--inview-i: 1">
          採用メッセージ
        </p>
        <IceLinkButton
          class="p-top-pioneer__button"
          href={`${basePath}message/`}
          label="採用メッセージ"
          basePath={basePath}
          fluid
          aria-label="採用メッセージを読む"
          data-inview="fade"
          style="--inview-i: 2"
        />
        <img
          class="p-top-pioneer__visual"
          src={`${basePath}images/top/pioneer.png`}
          alt=""
          aria-hidden="true"
        />
      </div>
    </section>

    {/* ============================================ */}
    {/* S3+S4. KNOW HOSHIZAKI / ここに決めた! (Figma y: 3283–5502 / 365:13388 帯) */}
    {/* ============================================ */}
    <section
      class="p-top-trio"
      aria-label="ホシザキを知る視点とはたらく人を知る導線"
    >
      <div class="p-top-trio__stage">
        {/* SP 用の絹布テクスチャ背景（Figma top_sp 431:4925 pixta_115239461。PC では非表示） */}
        <img
          class="p-top-trio__silk"
          src={`${basePath}images/top/trio-bg-silk-sp.jpg`}
          alt=""
          aria-hidden="true"
          loading="lazy"
        />

        {/* 装飾の氷キューブ（data-parallax: スクロール視差の速度係数） */}
        {
          trioCubeSpeeds.map((speed, idx) => (
            <img
              class={`p-top-trio__cube p-top-trio__cube--${idx + 1}`}
              src={`${basePath}images/top/ice_cubes_0${idx + 1}.png`}
              alt=""
              aria-hidden="true"
              data-parallax={speed}
            />
          ))
        }

        {/* SP 用の小さな氷キューブ 7 個（Figma top_sp ice 10/7/14/15/16/17/18。PC では非表示） */}
        {/* PC 用 ice_cubes_0x.png は 2〜3 個入りのため、単体キューブ画像を使う */}
        {
          [1, 2, 3, 4, 5, 6, 7].map((n) => (
            <img
              class={`p-top-trio__cube-sp p-top-trio__cube-sp--${n}`}
              src={`${basePath}images/top/ice_cube_sp.png`}
              alt=""
              aria-hidden="true"
              loading="lazy"
            />
          ))
        }

        {/* What's / Beyond / Team */}
        {
          trioCards.map((card) => (
            <Fragment>
              <img
                class={`p-top-trio__img p-top-trio__img--${card.pos}`}
                src={card.img}
                alt={card.imgAlt}
                data-inview
                style="--inview-i: 0"
              />
              <p
                class={`p-top-trio__en p-top-trio__en--${card.pos}`}
                data-inview
                style="--inview-i: 1"
              >
                <span class="p-top-trio__en-line">{card.en[0]}</span>
                <span class="p-top-trio__en-line">{card.en[1]}</span>
              </p>
              <IceLinkButton
                class={`p-top-trio__button p-top-trio__button--${card.pos}`}
                href={card.href}
                label={card.label}
                basePath={basePath}
                fluid
                data-inview="fade"
                style="--inview-i: 2"
              />
            </Fragment>
          ))
        }

        {/* SP では Beyond HOSHIZAKI の代わりに「世界へ跳べ」（Figma top_sp 431:4938。PC では非表示） */}
        {/* PC では display:none なので読み上げが重複することはない */}
        <p class="p-top-trio__ja-beyond" data-inview style="--inview-i: 1">
          世界へ跳べ
        </p>

        {/* 先輩たちの「ここに決めた！」 */}
        <img
          class="p-top-trio__img p-top-trio__img--decided"
          src={`${basePath}images/top/sec04_img.png`}
          alt="星型の氷フレームに収まった先輩社員たち"
          data-inview
          style="--inview-i: 0"
        />
        <p class="p-top-trio__decided-lead" data-inview style="--inview-i: 1">
          先輩たちの
        </p>
        <img
          class="p-top-trio__decided-koko"
          src={`${basePath}images/top/koko-decided.svg`}
          alt="「ここに決めた！」"
          data-inview
          style="--inview-i: 2"
        />

        {/* SP では筆文字 SVG ではなくテキスト 2 行（Figma top_sp 431:4974。PC では非表示） */}
        {/* PC では display:none なので読み上げが重複することはない */}
        <p class="p-top-trio__decided-sp" data-inview style="--inview-i: 2">
          <span class="p-top-trio__decided-sp-line1">　先輩たちの</span>
          <span class="p-top-trio__decided-sp-line2">「ここに決めた！」</span>
        </p>
        <IceLinkButton
          class="p-top-trio__button p-top-trio__button--decided"
          href={`${basePath}person/`}
          label="はたらく人を知る"
          basePath={basePath}
          fluid
          aria-label="はたらく人を知る"
          data-inview="fade"
          style="--inview-i: 3"
        />
      </div>
    </section>

    {/* ============================================ */}
    {/* S5. はたらく環境を知る (Figma y: 5502–6162 / Group 296:7285) */}
    {/* ============================================ */}
    <section class="p-top-env" aria-label="はたらく環境を知る">
      {/* 背景写真。SP は Figma top_sp 用に切り出した専用画像へ差し替える */}
      {/* （PC/SP それぞれ片方を CSS で display:none し入れ替え）。 */}
      <img
        class="p-top-env__photo p-top-env__photo--pc"
        src={`${basePath}images/top/section-bg-environment.jpg`}
        alt=""
        aria-hidden="true"
      />
      <img
        class="p-top-env__photo p-top-env__photo--sp"
        src={`${basePath}images/top/section-bg-environment_sp.png`}
        alt=""
        aria-hidden="true"
        loading="lazy"
      />
      <div class="p-top-env__inner">
        <header class="p-top-env__heading">
          <h2 class="p-top-env__title" data-inview style="--inview-i: 0">
            はたらく環境を知る
          </h2>
          <p class="p-top-env__sub" data-inview style="--inview-i: 1">
            制度も環境も、妥協せずに整えてきました。
          </p>
        </header>
        <IceLinkButton
          class="p-top-env__button"
          href={`${basePath}environment/`}
          label="はたらく環境を知る"
          basePath={basePath}
          aria-label="はたらく環境を知る"
          data-inview="fade"
          style="--inview-i: 2"
        />
      </div>
    </section>

    {/* ============================================ */}
    {/* S6. SPECIAL CONTENTS (Figma y: 6162–8450) */}
    {/* 見出し・カード・スクロール連動スタック演出は特集ページ（/special/）と */}
    {/* 共通の SpecialContents コンポーネントを使用する。 */}
    {/* ============================================ */}
    <section class="p-top-special" aria-label="特集コンテンツとエントリー導線">
      <div class="p-special">
        <SpecialContents
          basePath={basePath}
          storyBase={`${basePath}special/`}
          headingTag="h2"
        />
      </div>

      <BottomCta basePath={basePath} />
    </section>

    {/* ============================================ */}
    {/* コンセプトムービー モーダル */}
    {/* 初期は hidden。ボタン押下で開き、video を先頭から再生。 */}
    {/* 動画(約25MB)を初期ロードしないよう preload="none"。 */}
    {/* ============================================ */}
    <div
      class="c-movie-modal"
      id="concept-movie-modal"
      data-movie-modal
      role="dialog"
      aria-modal="true"
      aria-label="コンセプトムービー"
      hidden
    >
      <div class="c-movie-modal__backdrop" data-movie-close></div>
      <div class="c-movie-modal__dialog">
        <button
          type="button"
          class="c-movie-modal__close"
          data-movie-close
          aria-label="ムービーを閉じる"
        >
          <span class="c-movie-modal__close-icon" aria-hidden="true"></span>
        </button>
        <div class="c-movie-modal__frame">
          <video
            class="c-movie-modal__video"
            data-movie-video
            controls
            playsinline
            preload="none"
            poster={`${basePath}images/top/concept-movie-poster.png`}
          >
            <source src={`${basePath}videos/hoshizaki_01.mp4`} type="video/mp4" />
            お使いのブラウザは動画の再生に対応していません。
          </video>
        </div>
      </div>
    </div>
  </main>

  <Footer basePath={basePath} />
</Layout>
