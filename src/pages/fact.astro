---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/PageHero.astro";
import BottomCta from "../components/BottomCta.astro";
import Breadcrumb from "../components/Breadcrumb.astro";

const base = "../";
const img = (name: string) => `${base}images/fact/${name}`;
---

<Layout
  basePath={base}
  title="What's HOSHIZAKI｜ホシザキ本社採用サイト"
  description="数字で見るホシザキ。製氷機国内シェアNo.1の基盤と世界120ヶ国以上のネットワーク、社員の働きやすさを支える環境を数字で紹介します。"
>
  <div class="l-container">
    <Header basePath={base} />
    <main class="l-main">
      <article class="p-fact">
        <PageHero en="What's HOSHIZAKI" ja="数字で見るホシザキ" variant="cloud">
          <figure class="p-fact__hero-visual">
            <img
              src={img("page-fv.png")}
              alt="南極の氷山の頂上に立つアデリーペンギン"
              loading="eager"
              width="1283"
              height="430"
            />
          </figure>
        </PageHero>

        <!-- Intro -->
        <section class="p-fact__intro">
          <p class="p-fact__intro-text" data-inview>
            街中で見かける「ペンギンマーク」。その親しみやすさの裏側には、あなたの想像を超えるダイナミックな世界が広がっています。<br
            />
            製氷機国内シェアNo.1という盤石な基盤、世界五大陸を舞台にしたグローバルな躍進、そして一人ひとりの挑戦を支える確かな環境。<br
            />
            まだ見ぬホシザキの「驚き」と「可能性」を、確かな数字で解き明かします。
          </p>
        </section>

        <!-- Section A: Growth -->
        <section class="p-fact__section" aria-labelledby="fact-growth-title">
          <div class="p-fact__inner">
            <header class="p-fact__heading" id="fact-growth-title" data-inview>
              <p class="p-fact__heading-title">
                <img
                  class="p-fact__heading-mark"
                  src={img("heading-icon.png")}
                  alt=""
                  aria-hidden="true"
                  width="47"
                  height="46"
                />HOSHIZAKIの成長を知る
              </p>
              <p class="p-fact__heading-note">
                圧倒的なシェアとグローバルな広がりが、挑戦のフィールドです。
              </p>
            </header>

            <div class="p-fact__bento">
              <!-- Column 1 -->
              <div class="p-fact__col">
                <!-- 歴史 -->
                <article
                  class="c-stat-card c-stat-card--history c-stat-card--short"
                  data-inview="pop"
                  style="--inview-i: 0"
                >
                  <span class="c-stat-card__label">歴史</span>
                  <img
                    class="c-stat-card__bg"
                    src={img("icon-history.svg")}
                    alt=""
                    aria-hidden="true"
                  />
                  <div class="c-stat-card__main c-stat-card--history__main">
                    <p class="c-stat-card__figure">
                      <span class="c-stat-card__prefix">創業</span>
                      <span class="c-stat-card__num">1947</span>
                      <span class="c-stat-card__unit">年</span>
                    </p>
                  </div>
                </article>

                <!-- 受賞歴 / 製品の評価 -->
                <article
                  class="c-stat-card c-stat-card--award c-stat-card--tall"
                  data-inview="pop"
                  style="--inview-i: 1"
                >
                  <span class="c-stat-card__label">製品の評価</span>
                  <img
                    class="c-stat-card__bg"
                    src={img("award-laurel.png")}
                    alt=""
                    aria-hidden="true"
                  />
                  <div class="c-stat-card__main">
                    <p class="c-stat-card__sub">受賞回数</p>
                    <p class="c-stat-card__figure">
                      <span class="c-stat-card__num" data-countup>15</span>
                      <span class="c-stat-card__unit">回</span>
                    </p>
                  </div>
                </article>

                <!-- 社員数 -->
                <article
                  class="c-stat-card c-stat-card--staff c-stat-card--mid"
                  data-inview="pop"
                  style="--inview-i: 2"
                >
                  <span class="c-stat-card__label">社員数</span>
                  <div class="c-stat-card__main">
                    <p class="c-stat-card__figure">
                      <span class="c-stat-card__num" data-countup>1,157</span>
                      <span class="c-stat-card__suffix">名（単体）</span>
                    </p>
                    <span class="c-stat-card__people" aria-hidden="true">
                      <img src={img("people-icon.png")} alt="" />
                      <img src={img("people-icon.png")} alt="" />
                      <img src={img("people-icon.png")} alt="" />
                    </span>
                  </div>
                </article>
              </div>

              <!-- Column 2 -->
              <div class="p-fact__col">
                <!-- 業界シェア No.1 -->
                <article
                  class="c-stat-card c-stat-card--share c-stat-card--tall"
                  data-inview="pop"
                  style="--inview-i: 0"
                >
                  <span class="c-stat-card__label">業界シェア</span>
                  <img
                    class="c-stat-card__bg"
                    src={img("product-icemaker.png")}
                    alt=""
                    aria-hidden="true"
                  />
                  <div class="c-stat-card__main">
                    <img
                      class="c-stat-card__crown"
                      src={img("crown.png")}
                      alt=""
                      aria-hidden="true"
                    />
                    <p class="c-stat-card__sub">
                      製氷機　国内シェア<span class="p-fact__note-ref">※</span>
                    </p>
                    <p class="c-stat-card__figure">
                      <span class="c-stat-card__num">No.1</span>
                    </p>
                  </div>
                </article>

                <!-- 売上高 -->
                <article
                  class="c-stat-card c-stat-card--sales c-stat-card--short"
                  data-inview="pop"
                  style="--inview-i: 1"
                >
                  <span class="c-stat-card__label">売上高</span>
                  <img
                    class="c-stat-card__bg"
                    src={img("graph-sales.png")}
                    alt=""
                    aria-hidden="true"
                  />
                  <div class="c-stat-card__main">
                    <p class="c-stat-card__figure c-stat-card__figure--sales">
                      <span class="c-stat-card__num" data-countup>4,858</span><span
                        class="c-stat-card__unit">億</span
                      ><span class="c-stat-card__num" data-countup>9,000</span><span
                        class="c-stat-card__unit">万円</span
                      ><span class="c-stat-card__suffix">（連結）</span>
                    </p>
                  </div>
                </article>

                <!-- 国内ネットワーク -->
                <article
                  class="c-stat-card c-stat-card--domestic c-stat-card--mid"
                  data-inview="pop"
                  style="--inview-i: 2"
                >
                  <span class="c-stat-card__label">国内ネットワーク</span>
                  <img
                    class="c-stat-card__bg"
                    src={img("japan-map.png")}
                    alt=""
                    aria-hidden="true"
                  />
                  <div class="c-stat-card__main">
                    <p class="c-stat-card__figure c-stat-card__figure--stack">
                      <span class="c-stat-card__num" data-countup>427</span>
                      <span class="c-stat-card__unit">ヶ所の営業拠点</span>
                    </p>
                  </div>
                </article>
              </div>

              <!-- Column 3 -->
              <div class="p-fact__col">
                <!-- 製品機種 -->
                <article
                  class="c-stat-card c-stat-card--products c-stat-card--short"
                  data-inview="pop"
                  style="--inview-i: 0"
                >
                  <span class="c-stat-card__label">製品機種</span>
                  <span class="c-stat-card__products" aria-hidden="true">
                    <img src={img("product-icemaker.png")} alt="" />
                    <img src={img("product-02.png")} alt="" />
                    <img src={img("product-03.png")} alt="" />
                    <img src={img("product-04.png")} alt="" />
                  </span>
                  <div class="c-stat-card__main">
                    <p class="c-stat-card__figure">
                      <span class="c-stat-card__num" data-countup>600</span>
                      <span class="c-stat-card__unit">種以上</span>
                    </p>
                  </div>
                </article>

                <!-- 海外売上比率 -->
                <article
                  class="c-stat-card c-stat-card--overseas c-stat-card--tall"
                  data-inview="pop"
                  style="--inview-i: 1"
                >
                  <span class="c-stat-card__label">海外売上比率</span>
                  <div class="c-stat-card__main">
                    <div class="c-stat-card__pie" aria-hidden="true">
                      <span
                        class="c-stat-card__pie-label c-stat-card__pie-label--domestic"
                        >国内</span
                      >
                      <span
                        class="c-stat-card__pie-label c-stat-card__pie-label--overseas"
                        >海外</span
                      >
                    </div>
                    <p class="c-stat-card__figure">
                      <span class="c-stat-card__num" data-countup>45.9</span>
                      <span class="c-stat-card__unit c-stat-card__unit--pct"
                        >％</span
                      >
                    </p>
                  </div>
                </article>

                <!-- グローバル展開 -->
                <article
                  class="c-stat-card c-stat-card--global c-stat-card--mid"
                  data-inview="pop"
                  style="--inview-i: 2"
                >
                  <span class="c-stat-card__label">グローバル展開</span>
                  <img
                    class="c-stat-card__bg"
                    src={img("world-map.png")}
                    alt=""
                    aria-hidden="true"
                  />
                  <div class="c-stat-card__main">
                    <p class="c-stat-card__figure c-stat-card__figure--global">
                      <span class="c-stat-card__prefix">世界</span>
                      <span class="c-stat-card__num" data-countup>120</span>
                      <span class="c-stat-card__unit c-stat-card__unit--stack"
                        >ヶ国以上の<br />ネットワーク</span
                      >
                    </p>
                  </div>
                </article>
              </div>
            </div>

            <p class="p-fact__note" data-inview>
              <span class="p-fact__note-ref">※</span>製氷機の国内シェアNo.1は自社調べ（2022年度）によるものです。
            </p>
          </div>
        </section>

        <!-- Section B: Benefits -->
        <section class="p-fact__section" aria-labelledby="fact-benefits-title">
          <div class="p-fact__inner">
            <header class="p-fact__heading" id="fact-benefits-title" data-inview>
              <p class="p-fact__heading-title">
                <img
                  class="p-fact__heading-mark"
                  src={img("heading-icon.png")}
                  alt=""
                  aria-hidden="true"
                  width="47"
                  height="46"
                />長く、自分らしく働く【環境・福利厚生】
              </p>
              <p class="p-fact__heading-note">
                安定した経営基盤があるからこそ、一人ひとりの生活も大切にできます。
              </p>
            </header>

            <div class="p-fact__benefits">
              <!-- 平均勤続年数 -->
              <article
                class="c-stat-card c-stat-card--benefit c-benefit--tenure"
                data-inview="pop"
                style="--inview-i: 0"
              >
                <span class="c-stat-card__label">平均勤続年数</span>
                <div class="c-benefit__row">
                  <img
                    class="c-benefit__icon"
                    src={img("icon-tenure.svg")}
                    alt=""
                    aria-hidden="true"
                  />
                  <p class="c-stat-card__figure">
                    <span class="c-stat-card__num" data-countup>17.5</span>
                    <span class="c-stat-card__unit">年</span>
                  </p>
                </div>
                <p class="c-stat-card__desc">
                  社員が安心してキャリアを築ける環境があります。腰を据えて専門性を高め、長く活躍できるのがホシザキの強みです。
                </p>
              </article>

              <!-- 平均残業時間 -->
              <article
                class="c-stat-card c-stat-card--benefit c-benefit--overtime"
                data-inview="pop"
                style="--inview-i: 1"
              >
                <span class="c-stat-card__label">平均残業時間</span>
                <div class="c-benefit__row">
                  <p class="c-stat-card__figure">
                    <span class="c-stat-card__num" data-countup>13.1</span>
                    <span class="c-stat-card__unit">時間 / 月</span>
                  </p>
                  <img
                    class="c-benefit__icon"
                    src={img("icon-overtime.svg")}
                    alt=""
                    aria-hidden="true"
                  />
                </div>
                <p class="c-stat-card__desc">
                  効率的な働き方を推進。仕事の質を追求しながら、プライベートの時間も確保できる風土です。
                </p>
              </article>

              <!-- 有給休暇取得率 -->
              <article
                class="c-stat-card c-stat-card--benefit c-benefit--vacation"
                data-inview="pop"
                style="--inview-i: 2"
              >
                <span class="c-stat-card__label">有給休暇取得率</span>
                <div class="c-benefit__row">
                  <p class="c-stat-card__figure">
                    <span class="c-stat-card__num" data-countup>68.4</span>
                    <span class="c-stat-card__unit c-stat-card__unit--pct"
                      >％</span
                    >
                  </p>
                  <img
                    class="c-benefit__icon"
                    src={img("icon-vacation.svg")}
                    alt=""
                    aria-hidden="true"
                  />
                </div>
                <p class="c-stat-card__desc">
                  「休むときはしっかり休む」リフレッシュを推奨し、オンとオフの切り替えを大切にしています。
                </p>
              </article>

              <!-- 育児休暇取得率 -->
              <article
                class="c-stat-card c-stat-card--benefit c-benefit--childcare"
                data-inview="pop"
                style="--inview-i: 3"
              >
                <span class="c-stat-card__label">育児休暇取得率</span>
                <div class="c-benefit__row c-benefit__split">
                  <p class="c-stat-card__figure">
                    <span class="c-stat-card__figure-label">女性</span>
                    <span class="c-stat-card__num" data-countup>100</span>
                    <span class="c-stat-card__unit c-stat-card__unit--pct"
                      >％</span
                    >
                  </p>
                  <img
                    class="c-benefit__icon"
                    src={img("childcare.png")}
                    alt=""
                    aria-hidden="true"
                  />
                  <p class="c-stat-card__figure">
                    <span class="c-stat-card__figure-label">男性</span>
                    <span class="c-stat-card__num" data-countup>51.9</span>
                    <span class="c-stat-card__unit c-stat-card__unit--pct"
                      >％</span
                    >
                  </p>
                </div>
                <p class="c-stat-card__desc">
                  ライフステージが変わっても、キャリアを諦める必要はありません。特に男性の取得率も上昇しており、互いにサポートし合う文化が根付いています。
                </p>
              </article>
            </div>
          </div>
        </section>

        <!-- Bottom CTA -->
        <BottomCta basePath={base} />

        <!-- Breadcrumb -->
        <div class="p-fact__breadcrumb">
          <Breadcrumb
            basePath={base}
            items={[{ label: "数字とキーワードで見るホシザキ" }]}
          />
        </div>
      </article>
    </main>
    <Footer basePath={base} />
  </div>
</Layout>
