---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/PageHero.astro";
import IceHeading from "../components/IceHeading.astro";
import OfficeTourCarousel from "../components/OfficeTourCarousel.astro";
import BottomCta from "../components/BottomCta.astro";
import Breadcrumb from "../components/Breadcrumb.astro";

const base = "../";

// --------------------------------------------
// Training cards (Figma 485:1231 / 485:1242 / 485:1253 / 518:1128)
// --------------------------------------------
const trainingCards = [
  {
    title: "若手を支えるメンター制度",
    body: "入社1年目から3年目までの社員を対象にメンター制度を導入しています。2年目からのメンター選任は、部門や年次に関わらず、メンティー自身のリクエストを受けて調整する柔軟な仕組みです。",
    image: `${base}images/environment/img01.png`,
  },
  {
    title: "語学研修制度",
    body: "社員の主体的な学びを後押しするため、資格取得補助制度を設けています。",
    image: `${base}images/environment/img02.png`,
  },
  {
    title: "社内検定制度",
    body: "各種技能検定（製図、溶接、フォークリフトなど）や情報処理技術者、QC、内部監査員などの資格取得支援、昇進昇格認定を行っています。",
    image: `${base}images/environment/img03.png`,
  },
  {
    title: "選抜型研修制度",
    body: "次世代リーダーの育成を目的としたプログラムです。意欲的な社員に対しての能力開発の機会を提供し、自律的なキャリア選択を支援する仕組みとなっています。",
    image: `${base}images/environment/img04.png`,
  },
];

// --------------------------------------------
// Benefits (Figma 福利厚生 — 8 枚) — アイコンは Feather 系（stroke #2C82BB）
// --------------------------------------------
const svg = (inner: string) =>
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" focusable="false" aria-hidden="true">${inner}</svg>`;

const benefitIcons: Record<string, string> = {
  gift: svg(
    '<polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/>'
  ),
  award: svg(
    '<circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/>'
  ),
  pieChart: svg(
    '<path d="M21.21 15.89A10 10 0 1 1 8 2.83"/><path d="M22 12A10 10 0 0 0 12 2v10z"/>'
  ),
  trendingUp: svg(
    '<polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/>'
  ),
  book: svg(
    '<path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>'
  ),
  key: svg(
    '<path d="M21 2l-2 2"/><path d="M19 4l3 3-3.5 3.5-3-3z"/><path d="M11.39 11.61a5.5 5.5 0 1 1-7.78 7.78 5.5 5.5 0 0 1 7.78-7.78z"/><path d="M11.39 11.61L15.5 7.5"/>'
  ),
  home: svg(
    '<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>'
  ),
  coffee: svg(
    '<path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/>'
  ),
};

interface BenefitItem {
  title: string;
  body: string;
  icon: keyof typeof benefitIcons;
}

const benefits: BenefitItem[] = [
  {
    title: "福利厚生倶楽部（リロクラブ）",
    body: "多様なサービスを優待価格で利用できる会員制の福利厚生です。",
    icon: "gift",
  },
  {
    title: "退職金制度",
    body: "勤続年数などに応じて、退職時に退職金が支給される制度です。",
    icon: "award",
  },
  {
    title: "財形貯蓄制度",
    body: "給与天引きにより、無理なく計画的な資産形成を行える制度です。",
    icon: "pieChart",
  },
  {
    title: "社員持株制度",
    body: "自社株を定期的に購入でき、中長期的な資産形成を支援します。",
    icon: "trendingUp",
  },
  {
    title: "資格取得補助制度",
    body: "資格取得にかかる費用を会社が補助し、自己啓発を支援します。",
    icon: "book",
  },
  {
    title: "独身寮制度（入寮要件あり）",
    body: "遠方出身の若手社員などが安心して生活できるよう寮を貸与します。",
    icon: "key",
  },
  {
    title: "社宅制度",
    body: "転勤などの際、社員や家族が安心して生活できる社宅を貸与します。",
    icon: "home",
  },
  {
    title: "会社保養施設",
    body: "休暇を利用して心身をリフレッシュできる社員向けの保養施設です。",
    icon: "coffee",
  },
];

// --------------------------------------------
// Office Tour (Figma 拠点紹介) — Swiper カルーセル
// --------------------------------------------
const officeBase = `${base}images/environment/office-tour`;

interface OfficePhoto {
  src?: string;
  caption: string;
}

interface OfficeBlock {
  label: string;
  photos: OfficePhoto[];
}

const offices: OfficeBlock[] = [
  {
    // Figma 666:1519「オフィスツアー 豊明本社」— 掲載順・キャプションは同フレーム準拠
    label: "豊明本社",
    photos: [
      { src: `${officeBase}/toyoake/t01.jpg`, caption: "本社外観" },
      { src: `${officeBase}/toyoake/t02.jpg`, caption: "社員寮" },
      { src: `${officeBase}/toyoake/t03.jpg`, caption: "研修センター" },
      { src: `${officeBase}/toyoake/t04.jpg`, caption: "お城" },
      { src: `${officeBase}/toyoake/t05.jpg`, caption: "グラウンド" },
      { src: `${officeBase}/toyoake/t06.jpg`, caption: "中央研究所オフィス" },
      { src: `${officeBase}/toyoake/t07.jpg`, caption: "事務フロア" },
      { src: `${officeBase}/toyoake/t08.jpg`, caption: "工場" },
      { src: `${officeBase}/toyoake/t09.jpg`, caption: "食堂" },
      { src: `${officeBase}/toyoake/t10.jpg`, caption: "ショールーム" },
      { src: `${officeBase}/toyoake/t11.jpg`, caption: "記念館" },
    ],
  },
  {
    // Figma 743:1676「オフィスツアー 島根工場」— 掲載順・キャプションは同フレーム準拠
    label: "島根工場",
    photos: [
      { src: `${officeBase}/unnan/u01.jpg`, caption: "社屋外観" },
      { src: `${officeBase}/unnan/u02.jpg`, caption: "社屋外観" },
      { src: `${officeBase}/unnan/u03.jpg`, caption: "社屋外観" },
      { src: `${officeBase}/unnan/u04.jpg`, caption: "事務フロア" },
      { src: `${officeBase}/unnan/u05.jpg`, caption: "設計フロア" },
      { src: `${officeBase}/unnan/u06.jpg`, caption: "ショールーム" },
      { src: `${officeBase}/unnan/u07.jpg`, caption: "グラウンド" },
      { src: `${officeBase}/unnan/u08.jpg`, caption: "工場内休憩スペース" },
      { src: `${officeBase}/unnan/u09.jpg`, caption: "和室会議室" },
      { src: `${officeBase}/unnan/u10.jpg`, caption: "工場外観" },
      { src: `${officeBase}/unnan/u11.jpg`, caption: "薬師堂" },
      {
        src: `${officeBase}/unnan/u12.jpg`,
        caption: "ふるさと尺の内公園（ホシザキグリーン財団）",
      },
    ],
  },
];
---

<Layout
  basePath={base}
  title="Environment｜ホシザキ本社採用サイト"
  description="ホシザキ本社のはたらく環境。教育研修制度、福利厚生、愛知本社と島根工場の拠点情報を紹介します。"
>
  <link
    slot="head"
    rel="stylesheet"
    href={`${base}css/swiper-bundle.min.css`}
  />
  <script slot="head" src={`${base}js/swiper-bundle.min.js`} defer is:inline></script>

  <div class="l-container">
    <Header basePath={base} />
    <main class="l-main">
      <article class="p-env">
        <PageHero en="Environment" ja="はたらく環境を知る" variant="cloud" jaSize="lg">
          <div class="p-env__fv" data-inview="pop">
            <img
              src={`${base}images/environment/page-fv.png`}
              alt="ホシザキ本社（愛知県豊明市）の外観"
              loading="eager"
              width="1283"
              height="430"
            />
          </div>
        </PageHero>

        <!-- Training -->
        <section class="p-env__section">
          <div class="p-env__inner">
            <IceHeading
              en="Training"
              ja="教育研修制度"
              note="ホシザキでは、新人をしっかりと育成し長く働けるよう体制を整えています。"
              basePath={base}
              id="env-training"
            />

            <figure class="p-env-matrix" data-inview="pop">
              <img
                src={`${base}images/environment/training-system.png`}
                alt="教育研修体系図。キャリアステージ（役員/部長・課長・係長/主任・若手/新入社員・全階層共通）ごとに、階層別研修・幹部人材育成・女性活躍推進・能力開発の研修を整理した一覧。"
                width="1107"
                height="455"
                loading="lazy"
              />
            </figure>

            <ul class="p-env-training">
              {
                trainingCards.map((card, i) => (
                  <li class="p-env-training__item" data-inview style={`--inview-i: ${i}`}>
                    <div class="p-env-training__body">
                      <h3 class="p-env-training__title">
                        <img
                          class="p-env-training__ice"
                          src={`${base}images/common/ice-01.png`}
                          alt=""
                          width="22"
                          height="23"
                          aria-hidden="true"
                        />
                        <span>{card.title}</span>
                      </h3>
                      <p class="p-env-training__text">{card.body}</p>
                    </div>
                    <figure class="p-env-training__thumb">
                      <img src={card.image} alt="" loading="lazy" width="309" height="179" />
                    </figure>
                  </li>
                ))
              }
            </ul>
          </div>
        </section>

        <!-- Benefits -->
        <section class="p-env__section">
          <div class="p-env__inner">
            <IceHeading
              en="Benefits"
              ja="福利厚生"
              note="ホシザキの充実した福利厚生制度の一部をご紹介します。"
              basePath={base}
              id="env-benefits"
            />

            <ul class="p-env-benefits">
              {
                benefits.map((item, i) => (
                  <li class="p-env-benefits__item" data-inview style={`--inview-i: ${i % 4}`}>
                    <span class="p-env-benefits__icon" set:html={benefitIcons[item.icon]} />
                    <h3 class="p-env-benefits__title">{item.title}</h3>
                    <p class="p-env-benefits__text">{item.body}</p>
                  </li>
                ))
              }
            </ul>
          </div>
        </section>

        <!-- Office Tour -->
        <section class="p-env__section p-env__section--office">
          <div class="p-env__inner">
            <IceHeading
              en="Office Tour"
              ja="拠点紹介"
              note="愛知本社と島根工場のはたらく環境を紹介します。"
              basePath={base}
              id="env-office"
            />

            {
              offices.map((office) => (
                <OfficeTourCarousel label={office.label} photos={office.photos} />
              ))
            }
          </div>
        </section>

        <!-- Bottom CTA -->
        <BottomCta basePath={base} />

        <!-- Breadcrumb -->
        <div class="p-env__breadcrumb">
          <Breadcrumb basePath={base} items={[{ label: "はたらく環境を知る" }]} />
        </div>
      </article>
    </main>
    <Footer basePath={base} />
  </div>
</Layout>
