---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import BottomCta from "../components/BottomCta.astro";
import { specialStories } from "../data/specialStories";

const base = "../";

// 背景・アバター画像は配列インデックス（1 始まり）から導出する。
// トップページ（index.astro）の SPECIAL CONTENTS セクションと同じ規則。
const cards = specialStories.map((story, i) => {
  const n = String(i + 1).padStart(2, "0");
  return {
    href: `./${story.slug}/`,
    category: story.category,
    titleLines: story.titleLines,
    sub: story.sub,
    bg: `${base}images/special/${n}.png`,
    avatars: Array.from({ length: story.avatars }).map((_, a) => ({
      src: `${base}images/special/sp${n}_pic${String(a + 1).padStart(2, "0")}.png`,
      alt: `${story.category} 出演者 ${a + 1}`,
    })),
    modifier: story.slug,
  };
});
---

<Layout
  basePath={base}
  title="スペシャルコンテンツ｜ホシザキ本社採用サイト"
  description="ホシザキをさらに深く知るスペシャルコンテンツ。若手社員のクロストーク、開発プロジェクトストーリー、開発責任者によるスペシャルトークを掲載。"
>
  <div class="l-container">
    <Header basePath={base} />
    <main class="l-main">
      <article class="p-special">
        <!-- Hero -->
        <section class="p-special__hero" aria-labelledby="special-hero-title">
          <video
            class="p-special__hero-video"
            autoplay
            muted
            loop
            playsinline
            preload="auto"
            aria-hidden="true"
          >
            <source src={`${base}images/special/loop-mv.mp4`} type="video/mp4" />
          </video>
          <div class="p-special__hero-overlay" aria-hidden="true"></div>
          <img
            class="p-special__hero-silhouette"
            src={`${base}images/special/silhouette-penguin.png`}
            alt=""
            aria-hidden="true"
          />
          <div class="p-special__hero-inner">
            <h1 class="p-special__hero-title" id="special-hero-title">SPECIAL<br />CONTENTS</h1>
            <p class="p-special__hero-sub">ホシザキをさらに深く知るスペシャルコンテンツ</p>
          </div>
        </section>

        <!-- Cards -->
        <section class="p-special__cards" aria-label="スペシャルコンテンツ一覧">
          <ul class="p-special__list">
            {
              cards.map((card) => (
                <li class={`p-special__card p-special__card--${card.modifier}`}>
                  <a class="p-special__card-link" href={card.href}>
                    <div
                      class="p-special__card-photo"
                      style={`background-image: url('${card.bg}');`}
                      aria-hidden="true"
                    />
                    <div class="p-special__card-panel">
                      <p class="p-special__card-category">{card.category}</p>
                      <h2 class="p-special__card-title">
                        {card.titleLines.map((line, i) => (
                          <>
                            {line}
                            {i < card.titleLines.length - 1 && <br />}
                          </>
                        ))}
                      </h2>
                      <p class="p-special__card-sub">{card.sub}</p>
                      <ul class="p-special__card-avatars" aria-hidden="true">
                        {card.avatars.map((a) => (
                          <li class="p-special__card-avatar">
                            <img src={a.src} alt="" loading="lazy" width="48" height="48" />
                          </li>
                        ))}
                      </ul>
                    </div>
                    <span class="p-special__card-more">
                      READ MORE <span aria-hidden="true">→</span>
                    </span>
                  </a>
                </li>
              ))
            }
          </ul>
        </section>

        <BottomCta basePath={base} />
        <Breadcrumb basePath={base} items={[{ label: "スペシャルコンテンツ" }]} />
      </article>
    </main>
    <Footer basePath={base} />
  </div>
</Layout>
