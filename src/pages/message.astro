---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import BottomCta from "../components/BottomCta.astro";

const base = "../";

// 飛ぶペンギン（Figma 365:16897 の各 ap_0x）。
// ※ Figma の番号と表示順。ap_05 が中央の大ペンギン。
const heroPenguins = [
  { n: 2, img: "ap_02.png" },
  { n: 3, img: "ap_03.png" },
  { n: 5, img: "ap_05.png" },
  { n: 4, img: "ap_04.png" },
  { n: 1, img: "ap_01.png" },
];
---

<Layout
  basePath={base}
  title="採用メッセージ｜ホシザキ本社採用サイト"
  description="ホシザキ本社の採用メッセージ。積極性と学ぶ意欲を持ち、自分らしく活躍できる会社に出会うためのヒントをお届けします。"
>
  <div class="l-container">
    <Header basePath={base} />
    <main class="l-main">
      <article class="p-message">
        <!-- Hero (Figma 162:53 上部 y0–884) -->
        <section class="p-message-hero" aria-labelledby="message-hero-title">
          <div class="p-message-hero__stage">
            <div class="p-message-hero__sky" aria-hidden="true"></div>

            <img
              class="p-message-hero__cloud p-message-hero__cloud--left"
              src={`${base}images/common/hero-cloud.png`}
              alt=""
              aria-hidden="true"
            />
            <img
              class="p-message-hero__cloud p-message-hero__cloud--main"
              src={`${base}images/common/hero-cloud.png`}
              alt=""
              aria-hidden="true"
            />

            <h1 class="p-message-hero__title" id="message-hero-title">
              <span class="p-message-hero__title-line">常識の</span>
              <span class="p-message-hero__title-line">先へ、</span>
              <span class="p-message-hero__title-line">跳べ。</span>
            </h1>

            {
              heroPenguins.map((p) => (
                <img
                  class={`p-message-hero__penguin p-message-hero__penguin--${p.n}`}
                  src={`${base}images/message/${p.img}`}
                  alt=""
                  aria-hidden="true"
                />
              ))
            }

            <p class="p-message-hero__caption-en">PIONEER SPIRIT</p>
            <p class="p-message-hero__caption-ja">採用メッセージ</p>
          </div>
        </section>

        <!-- Body (Figma 162:53 本文ブロック) -->
        <section class="p-message-body" aria-label="採用メッセージ本文">
          <div class="p-message-body__inner">
            <!-- 採用ペンギン + 導入テキスト -->
            <div class="p-message-body__intro">
              <figure class="p-message-body__avatar" data-inview="left">
                <img
                  src={`${base}images/message/img01.png`}
                  alt="スーツを着た採用ペンギン"
                  loading="lazy"
                />
              </figure>
              <div class="p-message-body__text">
                <p class="p-message-body__paragraph" data-inview style="--inview-i: 0">
                  当社が求めるのは、どんなことにも積極的に取り組む姿勢です。任された仕事をただこなすのではなく、自分で考えたり工夫しながら取り組むことが自分の付加価値を高めることにつながります。次に、担当業務に限らずいろいろなことに興味を持ち学ぶ意欲。幅広い視野と知識を身に付ければ、自分の仕事の質を高めることができます。積極性と学ぶ意欲を持ち続けることで、多様なニーズに柔軟に対応できる提案力を身に付けることができます。
                </p>
                <p class="p-message-body__paragraph" data-inview style="--inview-i: 1">
                  当社の良さは、役職や部署などの垣根がなくコミュニケーションがとりやすいこと。
                </p>
              </div>
            </div>

            <!-- 本文 + 写真 -->
            <div class="p-message-body__main">
              <div class="p-message-body__text p-message-body__text--lower">
                <p class="p-message-body__paragraph" data-inview style="--inview-i: 0">
                  社内では肩書では呼ばず「さん」付けで呼びあっているほか、役員室がなく社員と経営層の間に壁もありません。
                </p>
                <p class="p-message-body__paragraph" data-inview style="--inview-i: 1">
                  性別・年齢・役職に関係なくさまざまな考え方を認め合う風土なので、誰とでも活発に意見交換できます。
                </p>
                <p class="p-message-body__paragraph" data-inview style="--inview-i: 2">
                  企業を選ぶうえでは、自分自身の「感性」も大切です。企業の規模や知名度だけでなく、「そこで活躍している自分自身がイメージできるか」「何を大切にしている会社か」など目に見えない情報を感じとってください。そのためには、直接企業で働く社員と会える機会を積極的に活用し、知りたいことを遠慮なく聞いていただきたいと思います。
                </p>
                <p class="p-message-body__paragraph p-message-body__paragraph--close" data-inview style="--inview-i: 3">
                  誰かにとってのいい会社ではなく、「あなたが自分らしく活躍できる会社」に出会えるよう、皆さんの就職活動の成功を心より応援しています。
                </p>
              </div>

              <div class="p-message-body__photos" aria-hidden="true" data-inview="right">
                <figure class="p-message-body__photo p-message-body__photo--upper">
                  <img
                    src={`${base}images/message/img02.png`}
                    alt=""
                    loading="lazy"
                  />
                </figure>
                <figure class="p-message-body__photo p-message-body__photo--lower">
                  <img
                    src={`${base}images/message/img03.png`}
                    alt=""
                    loading="lazy"
                  />
                </figure>
              </div>
            </div>
          </div>
        </section>

        <BottomCta basePath={base} />
        <Breadcrumb basePath={base} items={[{ label: "採用メッセージ" }]} />
      </article>
    </main>
    <Footer basePath={base} />
  </div>
</Layout>
