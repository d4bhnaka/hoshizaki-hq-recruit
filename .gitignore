# build output
dist/

# 大容量の動画アセットは Git 管理しない（別途管理し、ビルド/納品前に public/videos/ へ配置する）
public/videos/*.mp4
public/videos/*.mov
public/videos/*.webm

# compiled CSS (generated from src/scss/style.scss)
public/css/style.css

# generated types
.astro/

# dependencies
node_modules/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# environment variables
.env
.env.production

# macOS-specific files
.DS_Store

# jetbrains setting folder
.idea/

.playwright-mcp/
# Figma personal access token (never commit)
.figma_token

# Figma MCP アセット書き出しの一時ステージ（作業後に削除する）
.figma-stage/

# Python bytecode cache
__pycache__/

# Basic auth password file (never commit)
.htpasswd
scripts/_domain_raw/

