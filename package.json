{
  "name": "hoshizaki-hq-recruit",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "run-p watch:scss dev:astro",
    "dev:astro": "astro dev",
    "build": "npm run build:staging",
    "build:staging": "npm run clean && npm run build:scss && BUILD_ENV=staging astro build && npm run build:beautify && npm run build:strip-junk",
    "build:production": "npm run clean && npm run build:scss && BUILD_ENV=production SITE_URL=https://www.hoshizaki.co.jp/saiyou/ astro build && npm run build:beautify && npm run build:strip-junk",
    "build:scss": "sass src/scss/style.scss public/css/style.css --style expanded --no-source-map",
    "build:beautify": "find dist -name '*.html' -exec npx js-beautify --type html -r {} +",
    "build:strip-junk": "find dist -name '.DS_Store' -delete",
    "clean": "rm -rf dist",
    "watch:scss": "sass src/scss/style.scss public/css/style.css --style expanded --no-source-map --watch",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^7.0.6",
    "gsap": "^3.15.0",
    "lenis": "^1.3.25",
    "swiper": "^14.0.2"
  },
  "devDependencies": {
    "js-beautify": "^2.0.3",
    "npm-run-all2": "^9.0.2",
    "prettier": "^3.9.4",
    "sass": "^1.101.0"
  }
}
