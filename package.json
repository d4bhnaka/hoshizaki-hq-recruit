{
  "name": "hoshizaki-hq-recruit",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "npm run build:staging",
    "build:staging": "npm run build:scss && BUILD_ENV=staging astro build && npm run build:beautify",
    "build:production": "npm run build:scss && BUILD_ENV=production SITE_URL=https://www.hoshizaki.co.jp/saiyou/ astro build && npm run build:beautify",
    "build:scss": "sass src/scss/style.scss public/css/style.css --style expanded --no-source-map",
    "build:beautify": "find dist -name '*.html' -exec npx js-beautify --type html -r {} +",
    "watch:scss": "sass src/scss/style.scss public/css/style.css --style expanded --no-source-map --watch",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "astro": "^6.3.3",
    "gsap": "^3.15.0",
    "lenis": "^1.3.23",
    "swiper": "^12.1.4"
  },
  "devDependencies": {
    "js-beautify": "^1.15.4",
    "prettier": "^3.8.3",
    "sass": "^1.99.0"
  }
}
